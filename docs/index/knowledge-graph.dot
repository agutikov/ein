    // =================================================================
    // CROSS-CLUSTER LINK ARCS — logical / conceptual connections
    // (dashed blue = concept link, dotted red = substrate/impl,
    //  dashed purple = sibling/alias, bold green = pipeline)
    //
    // All edges below are constraint=false so they decorate without
    // pulling clusters into each other (avoids cluster overlap).
    // =================================================================

    edge [constraint=false];

    // --- 06 ↔ 03/04/05 : cross-cluster intra-section edges relocated here ---
    UnionFind -> HindleyMilner    [style=dotted, color=red,   label="powers"];
    GraphRewriting -> DPO         [style=dotted, color=red,   label="formalised by"];
    GraphReduction -> GHC         [style=dotted, color=red,   label="run by"];

    // --- 01 ↔ 02 : grammar/verifier ↔ solvers ---
    GCR        -> KnowledgeGraph   [style=dashed, color=blue,  label="constrains\npaths in"];
    VerifierGuided -> Z3           [style=dashed, color=blue,  label="symbolic\nverifier"];
    VerifierGuided -> SMT          [style=dashed, color=blue];
    NeuroSymAI -> SAT              [style=dashed, color=blue,  label="symbolic\nsearch"];
    NeuroSymAI -> SMT              [style=dashed, color=blue];

    // --- 01 ↔ 06 : KG-Trie / GCR ↔ knowledge graphs ---
    KGTrie -> KnowledgeGraph       [style=dashed, color=blue,  label="trie over"];

    // --- 01 ↔ 09 : LLM as policy / neurosymbolic ---
    NeuroSymAI -> NeuroSymAI_09    [style=dashed, color=purple, label="alias"];
    ConstOfT -> MCTS               [style=dashed, color=blue,   label="uses"];
    GCR -> GCR_09                  [style=dashed, color=purple];
    CRANE -> LLMAsPolicy           [style=dashed, color=blue];

    // --- 01 ↔ 04 : Lisp / SMT-LIB as LLM-emit IR ---
    SMTLIB_lang -> SMTLIB          [style=dashed, color=purple, label="same\nstandard"];
    HybridScratchpad -> miniKanren [style=dashed, color=blue,   label="clean IR\nexemplar"];

    // --- 02 ↔ 03 : SAT/SMT ↔ ATPs/ITPs ---
    Resolution -> SAT              [style=dashed, color=blue,  label="proof\nsystem"];
    Z3 -> SymExec                  [style=dashed, color=blue,  label="discharges\nfor"];
    SMT -> SymExec                 [style=dashed, color=blue];

    // --- 02 ↔ 06 : implication graph, congruence closure, e-graphs ---
    ImplGraph -> DirGraph          [style=dotted, color=red,   label="kind of"];
    CongrClos -> CongrClos06       [style=dashed, color=purple, label="same\nconcept"];
    CongrClos06 -> EGraph          [style=dashed, color=blue,   label="cousin of"];
    ClauseVarBipartite -> Bipartite [style=dotted, color=red];
    ConstraintHypergraph -> Hypergraph [style=dotted, color=red];
    ConstraintHypergraph -> ConstrHGraphIR [style=dashed, color=purple, label="same\nstructure"];

    // --- 02 ↔ 11 : solver search algos ---
    CDCL_02 -> CDCL                [style=dashed, color=purple];
    DPLL_02 -> DPLL                [style=dashed, color=purple];
    Backtracking_02 -> Backtracking[style=dashed, color=purple];
    ArcConsistency -> AC3          [style=dashed, color=purple];
    PathConsistency -> PathCons    [style=dashed, color=purple];
    ModelEnum -> BackboneEnum      [style=dashed, color=purple];
    UnsatCore -> UnsatCore_11      [style=dashed, color=purple];

    // --- 03 ↔ 05 : CT formalises proofs / triangle = composition ---
    Lean -> LeanMathlibCT          [style=dashed, color=purple];
    DepTypes -> CurryHoward        [style=dashed, color=blue];
    NaturalDeduction -> Category   [style=dashed, color=blue,  label="composition\nas inference"];
    ProofDAG -> DAG                [style=dotted, color=red,   label="is a"];
    TheoremDepGraph -> DAG         [style=dotted, color=red];

    // --- 03 ↔ 06 : proof graphs, automata, model checking ---
    ModelChecking -> ModelChecking_06 [style=dashed, color=purple];
    HindleyMilner -> UnionFind       [style=dashed, color=blue,  label="internally\nunifies via"];
    Resolution -> SWIProlog          [style=dashed, color=blue,  label="executed by"];

    // --- 03 ↔ 07 : verified compilers / abstract interp ---
    Astree_03 -> Astree            [style=dashed, color=purple];
    Infer_03  -> Infer             [style=dashed, color=purple];
    FramaC_03 -> FramaC            [style=dashed, color=purple];
    HindleyMilner -> AbstractInterp[style=dashed, color=blue,  label="kind of"];

    // --- 03 ↔ 11 : MCTS / AlphaZero-style proof search ---
    AlphaZeroGuided -> ProofDAG    [style=dashed, color=blue,  label="searches\nover"];

    // --- 04 ↔ 05/07 : Haskell/Julia/Lean as CT/IR hosts ---
    Haskell -> HaskellAsCT         [style=dashed, color=purple];
    Julia -> CatlabJL_05           [style=dotted, color=red,   label="hosts"];
    Rust -> Egg                    [style=dotted, color=red,   label="hosts"];
    CPP -> llamacpp                [style=dotted, color=red];
    CPP -> ORTools                 [style=dotted, color=red];
    CPP -> DearImGui               [style=dotted, color=red];
    CPP -> OGDF                    [style=dotted, color=red];
    Python -> Pydantic             [style=dotted, color=red,   label="hosts"];
    Python -> DisCoPy              [style=dotted, color=red];
    JavaScript -> CytoscapeJS      [style=dotted, color=red];
    JavaScript -> ReactFlow        [style=dotted, color=red];
    JavaScript -> SigmaJS          [style=dotted, color=red];
    JavaScript -> JointJS          [style=dotted, color=red];
    JavaScript -> AntVX6           [style=dotted, color=red];
    JavaScript -> Konva            [style=dotted, color=red];
    JavaScript -> FabricJS         [style=dotted, color=red];

    // --- 05 ↔ 06 : DPO/SPO, term rewriting, e-graphs ---
    DPO -> GraphRewriting          [style=dashed, color=blue,  label="categorical\nfoundation"];
    SPO -> GraphRewriting          [style=dashed, color=blue];
    TermRewriteCT -> TermRewriting [style=dashed, color=purple];
    CategoricalRewriting -> EqSat  [style=dashed, color=blue,  label="ancestor of"];

    // --- 05 ↔ 08 : diagram tools ---
    GraphvizDOT -> Graphviz_08     [style=dashed, color=purple];

    // --- 06 ↔ 07 : compiler graphs, e-graphs in MLIR, SSA ---
    EGraph -> MLIRplusEqSat        [style=dashed, color=blue];
    Tensat -> Tensat_07            [style=dashed, color=purple];
    Diospyros -> Diospyros_07      [style=dashed, color=purple];
    Herbie -> Herbie_07            [style=dashed, color=purple];
    SPORES -> SPORES_07            [style=dashed, color=purple];
    SSA_06 -> SSA_07               [style=dashed, color=purple];
    CFG -> SymExec                 [style=dashed, color=blue,  label="traversed by"];

    // --- 06 ↔ 09 : AtomSpace, KG ---
    AtomSpace_06 -> AtomSpace      [style=dashed, color=purple];
    KnowledgeGraph -> KGAI         [style=dashed, color=blue];
    Hypergraph -> AtomSpace        [style=dotted, color=red,  label="typed\nhypergraph"];

    // --- 06 ↔ 10 : hypergraph IR target ---
    Hypergraph -> ConstrHGraphIR   [style=dotted, color=red,  label="shape of"];
    ProofStateGraph -> ProofDAG    [style=dashed, color=blue, label="generalises"];

    // --- 07 ↔ 11 : equality sat & superopt ---
    Superopt -> Superopt_11        [style=dashed, color=purple];
    EqSat -> EqSat_11              [style=dashed, color=purple];

    // --- 08 ↔ 06/10 : diagram libs as KG visualisers ---
    ReactFlow -> KnowledgeGraph    [style=dashed, color=blue,  label="visualises"];
    CytoscapeJS -> KnowledgeGraph  [style=dashed, color=blue,  label="visualises"];
    SigmaJS -> KnowledgeGraph      [style=dashed, color=blue];
    LangFlow -> LangGraph          [style=dashed, color=blue,  label="analogue of"];

    // --- 09 ↔ 02 / 11 : TMS, CDCL, hypothesis branching ---
    ATMS -> CDCL                   [style=dashed, color=blue,  label="structurally\nsame loop"];
    ATMS -> HypothesisBranching    [style=dashed, color=blue];
    EinBot -> HypothesisBranching  [style=dashed, color=blue,  label="implements"];
    EinBot -> ConstrHGraphIR       [style=dashed, color=blue,  label="typed relational\nhypergraph"];
    EinBot -> AtomSpace            [style=dashed, color=blue,  label="kin to"];
    EinBot -> ATMS                 [style=dashed, color=blue,  label="kin to"];
    EinBot -> NaturalDeduction     [style=dashed, color=blue,  label="trace goal"];
    EinBot -> Tableau              [style=dashed, color=blue,  label="trace goal"];

    // --- 09 ↔ 11 : MOSES / evolutionary ---
    MOSES -> MOSES_11              [style=dashed, color=purple];

    // --- 10 ↔ 02 : compile to solvers (pipeline) ---
    BackendCompiler -> MiniZinc    [color="darkgreen", penwidth=2.0, label="emits"];
    BackendCompiler -> Z3          [color="darkgreen", penwidth=2.0];
    BackendCompiler -> Clingo      [color="darkgreen", penwidth=2.0];
    BackendCompiler -> CLPFD       [color="darkgreen", penwidth=2.0];
    BackendCompiler -> CPSAT       [color="darkgreen", penwidth=2.0];
    TaskFindContrad -> UnsatCore   [style=dashed, color=blue,  label="needs"];
    TaskFindAmbig -> ModelEnum     [style=dashed, color=blue];

    // --- 10 ↔ 05 : NL→IR as functor ---
    SemParsing -> Functor          [style=dashed, color=blue,  label="categorical\nview"];

    // --- 10 ↔ 01 : LLM extraction & GBNF ---
    GBNF_10 -> GBNF                [style=dashed, color=purple];
    SchemaGuidedExtract -> SGR     [style=dashed, color=purple];

    // --- 05 ↔ 04 : Lean / Catlab / Haskell ---
    LeanMathlibCT -> Lean          [style=dotted, color=red];
    HaskellAsCT -> Haskell         [style=dotted, color=red];

    // --- 11 ↔ 02 / 06 : unit propagation ↔ BCP / arc-consistency ↔ AC-3 ---
    UnitProp -> CDCL_02            [style=dotted, color=red,   label="inner loop"];
    BackboneEnum -> ModelEnum      [style=dashed, color=purple];

    // --- "Three representational tiers" ladder (06 §10) ---
    DirGraph -> DAG                [color="grey30", style=bold, label="+ sharing"];
    DAG -> EGraph                  [color="grey30", style=bold, label="+ equivalence"];
    EGraph -> Category             [color="grey30", style=bold, label="+ composition\nlaws"];

    // --- "Conceptual structure" pipeline (02 §9) ---
    LogicProg -> CSP               [color="darkgreen", style=bold];
    CSP -> Backtracking            [color="darkgreen", style=bold];
    Backtracking -> ProofDAG       [color="darkgreen", style=bold];
    ProofDAG -> LP                 [color="darkgreen", style=bold, label="→ optimisation"];
    LP -> ProgramSynthesis         [color="darkgreen", style=bold];
    ProgramSynthesis -> VerifiedOpt[color="darkgreen", style=bold];
}
