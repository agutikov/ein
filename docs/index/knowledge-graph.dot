// =====================================================================
// Knowledge graph of docs/index/ topics — every item mentioned across
// 01-llm-constrained-generation.md … 11-search-optimization-algorithms.md
//
// Multilevel grouping:
//   * 11 top-level clusters (one per index file)
//   * Each top-level cluster contains 2–6 nested sub-clusters
//     (mirroring the section headings inside the file)
//
// Visual encoding (shape + colour):
//   * ellipse        / lightblue   — abstract concept / theoretical notion
//   * hexagon        / khaki1      — algorithm
//   * box3d          / palegreen   — software, tool, library, system
//   * note           / peachpuff   — paper, named framework, publication
//   * cylinder       / pink        — programming language
//   * folder         / plum1       — data structure / IR / graph kind
//   * tab            / lightgrey   — standard, format, spec
//   * diamond        / gold        — problem class
//   * doubleoctagon  / lightcoral  — cognitive / agent architecture
//   * parallelogram  / lightcyan   — diagram language / notation / DSL
//   * component      / wheat       — proof structure
//   * septagon       / thistle     — abstract domain / lattice
//
// Edges:
//   * solid black            — "lives-in / contains / is-an-instance-of"
//                              (kept implicit through clusters; only used
//                              where an item belongs to two siblings).
//   * dashed blue            — conceptual cross-link between clusters
//   * dotted red             — "is the substrate / implementation of"
//   * bold green             — pipeline flow (NL → IR → solver → proof)
//   * dashed purple          — "alias / sibling / very close cousin of"
// =====================================================================

digraph KnowledgeGraph {
    graph [ rankdir=LR, compound=true, splines=polyline, overlap=false,
            clusterrank=local,
            fontname="Helvetica", fontsize=11, nodesep=0.45, ranksep=1.1,
            bgcolor="white", labelloc="t",
            label="Ein / docs/index — Knowledge Graph of all topics" ];
    node  [ fontname="Helvetica", fontsize=10, style="filled" ];
    edge  [ fontname="Helvetica", fontsize=9, color="grey40" ];

    // ----- Reusable style macros via node defaults inside sub-clusters
    // (Graphviz has no real macros; styles are applied per-node.)

    // =================================================================
    // 01 — LLM & Constrained Generation
    // =================================================================
    subgraph cluster_01 {
        label="01 — LLM & Constrained Generation";
        style="rounded,filled"; fillcolor="#f4f8ff"; color="#3a5fb0";
        fontsize=14; fontcolor="#1f3a78";

        subgraph cluster_01_internals {
            label="Inference internals"; style="dashed"; color="#5577cc";
            Logit       [shape=ellipse, fillcolor=lightblue, label="Logit"];
            Softmax     [shape=ellipse, fillcolor=lightblue, label="Softmax"];
            Temperature [shape=hexagon, fillcolor=khaki1,  label="Temperature /\ntop-k / top-p"];
            Tokenization[shape=ellipse, fillcolor=lightblue, label="Tokenization /\nvocabulary"];
            BPE         [shape=ellipse, fillcolor=lightblue, label="Byte-Pair\nEncoding (BPE)"];
            llamacpp    [shape=box3d,   fillcolor=palegreen, label="llama.cpp"];
            NucleusPaper[shape=note,    fillcolor=peachpuff, label="Holtzman 2019\n(nucleus sampling)"];
        }

        subgraph cluster_01_gbnf {
            label="Grammar-constrained decoding"; style="dashed"; color="#5577cc";
            GBNF             [shape=tab, fillcolor=lightgrey, label="GBNF\n(GGML BNF)"];
            BNF              [shape=tab, fillcolor=lightgrey, label="BNF"];
            EBNF             [shape=tab, fillcolor=lightgrey, label="EBNF"];
            ParserGuidedDec  [shape=hexagon, fillcolor=khaki1, label="Parser-guided\ndecoding"];
            HybridScratchpad [shape=ellipse, fillcolor=lightblue, label="Hybrid\nscratchpad pattern"];
        }

        subgraph cluster_01_crf {
            label="Constrained reasoning frameworks"; style="dashed"; color="#5577cc";
            ConstOfT [shape=note, fillcolor=peachpuff, label="Const-of-Thought\n(Const-o-T)"];
            GCR      [shape=note, fillcolor=peachpuff, label="GCR — Graph-\nConstrained Reasoning"];
            CRANE    [shape=note, fillcolor=peachpuff, label="CRANE"];
            SGR      [shape=note, fillcolor=peachpuff, label="Schema-Guided\nReasoning (SGR)"];
            KGTrie   [shape=folder, fillcolor=plum1, label="KG-Trie"];
            Pydantic [shape=box3d, fillcolor=palegreen, label="Pydantic"];
        }

        subgraph cluster_01_neurosym {
            label="Neuro-symbolic / verifier-guided"; style="dashed"; color="#5577cc";
            NeuroSymAI       [shape=doubleoctagon, fillcolor=lightcoral, label="Neuro-symbolic AI"];
            VerifierGuided   [shape=ellipse, fillcolor=lightblue, label="Verifier-guided /\nproof-constrained inference"];
            SelfModLang      [shape=ellipse, fillcolor=lightblue, label="Self-modifying\nconstraint languages"];
            ToolCalling      [shape=ellipse, fillcolor=lightblue, label="Tool-calling /\nstructured output"];
        }

        subgraph cluster_01_layers {
            label="Three levels of constraint"; style="dashed"; color="#5577cc";
            LayerSyntax    [shape=ellipse, fillcolor=lightblue, label="Syntax layer\n(token-local)"];
            LayerSemantic  [shape=ellipse, fillcolor=lightblue, label="Semantic admissibility\n(state-space)"];
            LayerGlobal    [shape=ellipse, fillcolor=lightblue, label="Global validity\n(whole proof)"];
        }

        // Internal edges (within 01)
        Logit -> Softmax [label="→ p(token)"];
        Logit -> Temperature [label="reshape"];
        GBNF -> BNF [label="derives from", style=dashed, color=purple];
        GBNF -> EBNF [label="derives from", style=dashed, color=purple];
        GBNF -> ParserGuidedDec [label="instance of", style=dashed, color=purple];
        ParserGuidedDec -> Logit [label="masks", color=red, style=dotted];
        HybridScratchpad -> CRANE [label="formalised as", style=dashed, color=purple];
        GCR -> KGTrie [label="indexed by"];
        SGR -> Pydantic [label="canonical substrate"];
        GBNF -> LayerSyntax [style=dotted, color=red];
        KGTrie -> LayerSemantic [style=dotted, color=red];
        VerifierGuided -> LayerGlobal [style=dotted, color=red];
        llamacpp -> GBNF [label="hosts"];
        Tokenization -> BPE [label="e.g."];
    }

    // =================================================================
    // 02 — Solvers (CSP / SAT / SMT / CP / LP / Logic programming)
    // =================================================================
    subgraph cluster_02 {
        label="02 — Solvers: CSP / SAT / SMT / CP / LP / Logic";
        style="rounded,filled"; fillcolor="#fff7f0"; color="#b06030";
        fontsize=14; fontcolor="#783a1f";

        subgraph cluster_02_problems {
            label="Problem classes"; style="dashed"; color="#cc8855";
            CSP   [shape=diamond, fillcolor=gold, label="CSP"];
            SAT   [shape=diamond, fillcolor=gold, label="Boolean SAT"];
            SMT   [shape=diamond, fillcolor=gold, label="SMT"];
            CP    [shape=diamond, fillcolor=gold, label="Constraint\nProgramming"];
            LP    [shape=diamond, fillcolor=gold, label="Linear\nProgramming"];
            MILP  [shape=diamond, fillcolor=gold, label="MILP / MIP"];
            ASP   [shape=diamond, fillcolor=gold, label="Answer-Set\nProgramming"];
            LogicProg [shape=diamond, fillcolor=gold, label="Logic\nProgramming"];
        }

        subgraph cluster_02_sat {
            label="SAT solvers"; style="dashed"; color="#cc8855";
            MiniSAT [shape=box3d, fillcolor=palegreen, label="MiniSAT"];
            Glucose [shape=box3d, fillcolor=palegreen, label="Glucose"];
            CaDiCaL [shape=box3d, fillcolor=palegreen, label="CaDiCaL"];
            Kissat  [shape=box3d, fillcolor=palegreen, label="Kissat"];
            CDCL_02 [shape=hexagon, fillcolor=khaki1, label="CDCL"];
            DPLL_02 [shape=hexagon, fillcolor=khaki1, label="DPLL"];
            ImplGraph [shape=folder, fillcolor=plum1, label="Implication\ngraph"];
            ClauseVarBipartite [shape=folder, fillcolor=plum1, label="Clause–variable\nbipartite graph"];
        }

        subgraph cluster_02_smt {
            label="SMT solvers"; style="dashed"; color="#cc8855";
            Z3       [shape=box3d, fillcolor=palegreen, label="Z3"];
            CVC5     [shape=box3d, fillcolor=palegreen, label="CVC5"];
            Yices    [shape=box3d, fillcolor=palegreen, label="Yices"];
            SMTLIB   [shape=tab, fillcolor=lightgrey, label="SMT-LIB"];
            CongrClos[shape=hexagon, fillcolor=khaki1, label="Congruence\nclosure"];
        }

        subgraph cluster_02_cp {
            label="CP / MIP / OR"; style="dashed"; color="#cc8855";
            MiniZinc  [shape=cylinder, fillcolor=pink, label="MiniZinc"];
            Essence   [shape=cylinder, fillcolor=pink, label="Essence /\nConjure"];
            ORTools   [shape=box3d,   fillcolor=palegreen, label="OR-Tools"];
            Gurobi    [shape=box3d,   fillcolor=palegreen, label="Gurobi"];
            CPLEX     [shape=box3d,   fillcolor=palegreen, label="CPLEX"];
            SCIP      [shape=box3d,   fillcolor=palegreen, label="SCIP"];
            CPSAT     [shape=box3d,   fillcolor=palegreen, label="CP-SAT"];
        }

        subgraph cluster_02_asp {
            label="ASP systems"; style="dashed"; color="#cc8855";
            Clingo [shape=box3d, fillcolor=palegreen, label="Clingo"];
            DLV    [shape=box3d, fillcolor=palegreen, label="DLV"];
        }

        subgraph cluster_02_logic {
            label="Logic programming"; style="dashed"; color="#cc8855";
            SWIProlog  [shape=cylinder, fillcolor=pink, label="SWI-Prolog"];
            Datalog    [shape=cylinder, fillcolor=pink, label="Datalog"];
            Mercury    [shape=cylinder, fillcolor=pink, label="Mercury"];
            miniKanren [shape=cylinder, fillcolor=pink, label="miniKanren"];
            CLPFD      [shape=cylinder, fillcolor=pink, label="CLP(FD)"];
        }

        subgraph cluster_02_propag {
            label="Constraint propagation / consistency"; style="dashed"; color="#cc8855";
            AllDifferent  [shape=ellipse, fillcolor=lightblue, label="All-different /\nglobal constraints"];
            ArcConsistency[shape=hexagon, fillcolor=khaki1, label="Arc consistency\n(AC-3 / AC-4)"];
            PathConsistency[shape=hexagon, fillcolor=khaki1, label="Path consistency"];
            Backtracking_02[shape=hexagon, fillcolor=khaki1, label="Backtracking /\nhypothesis testing"];
            AllenAlgebra  [shape=ellipse, fillcolor=lightblue, label="Allen interval\nalgebra"];
            RCC           [shape=ellipse, fillcolor=lightblue, label="Region\nConnection\nCalculus"];
        }

        subgraph cluster_02_analysis {
            label="Analysis on top of a model"; style="dashed"; color="#cc8855";
            ModelEnum   [shape=hexagon, fillcolor=khaki1, label="Model enumeration /\nbackbone analysis"];
            UnsatCore   [shape=hexagon, fillcolor=khaki1, label="Unsat core /\nMUS"];
            ConstraintHypergraph [shape=folder, fillcolor=plum1, label="Constraint\nhypergraph"];
        }

        // Internal edges
        SAT -> SMT [label="extended by", style=dashed, color=purple];
        CSP -> CP  [label="modelled by", style=dashed, color=purple];
        LP  -> MILP [label="+integer vars"];
        DPLL_02 -> CDCL_02 [label="ancestor of", style=dashed, color=purple];
        MiniSAT -> Glucose -> CaDiCaL -> Kissat [label="lineage", style=dashed, color=purple];
        CDCL_02 -> ImplGraph [label="analyses"];
        SAT -> ClauseVarBipartite [style=dotted, color=red];
        Z3 -> SMTLIB [label="reads", style=dashed];
        CVC5 -> SMTLIB [style=dashed];
        Yices -> SMTLIB [style=dashed];
        SMT -> CongrClos [label="uses", style=dotted, color=red];
        ORTools -> CPSAT [label="contains"];
        CPSAT -> CP [style=dotted, color=red];
        CPSAT -> SAT [style=dotted, color=red];
        ArcConsistency -> PathConsistency [label="strengthens", style=dashed, color=purple];
        SWIProlog -> CLPFD [label="hosts"];
        SWIProlog -> LogicProg [style=dotted, color=red];
        Datalog -> LogicProg [style=dotted, color=red];
        Clingo -> ASP [style=dotted, color=red];
        DLV -> ASP [style=dotted, color=red];
    }

    // =================================================================
    // 03 — Theorem Proving & Formal Methods
    // =================================================================
    subgraph cluster_03 {
        label="03 — Theorem Proving & Formal Methods";
        style="rounded,filled"; fillcolor="#f5fff0"; color="#2f7030";
        fontsize=14; fontcolor="#1f5018";

        subgraph cluster_03_itp {
            label="Interactive theorem provers (ITP)"; style="dashed"; color="#4f9050";
            Lean      [shape=cylinder, fillcolor=pink, label="Lean / mathlib"];
            Coq       [shape=cylinder, fillcolor=pink, label="Coq"];
            Isabelle  [shape=box3d,   fillcolor=palegreen, label="Isabelle /\nIsabelle/HOL"];
            Agda      [shape=cylinder, fillcolor=pink, label="Agda"];
            Idris     [shape=cylinder, fillcolor=pink, label="Idris"];
            ACL2      [shape=box3d,   fillcolor=palegreen, label="ACL2"];
        }

        subgraph cluster_03_atp {
            label="Automated theorem provers (ATP)"; style="dashed"; color="#4f9050";
            Vampire   [shape=box3d, fillcolor=palegreen, label="Vampire"];
            EProver   [shape=box3d, fillcolor=palegreen, label="E"];
            Prover9   [shape=box3d, fillcolor=palegreen, label="Prover9 /\nMace4"];
        }

        subgraph cluster_03_foundations {
            label="Foundations"; style="dashed"; color="#4f9050";
            CurryHoward [shape=ellipse, fillcolor=lightblue, label="Curry–Howard\ncorrespondence"];
            DepTypes    [shape=ellipse, fillcolor=lightblue, label="Dependent types"];
            TypeTheory  [shape=ellipse, fillcolor=lightblue, label="Type theory\n(Martin-Löf, CIC)"];
            HoTT        [shape=ellipse, fillcolor=lightblue, label="HoTT"];
            HindleyMilner[shape=hexagon, fillcolor=khaki1, label="Hindley–Milner\ntype inference"];
        }

        subgraph cluster_03_proofstruct {
            label="Proof structures"; style="dashed"; color="#4f9050";
            ProofTree   [shape=component, fillcolor=wheat, label="Proof tree"];
            ProofDAG    [shape=component, fillcolor=wheat, label="Proof DAG"];
            TheoremDepGraph [shape=folder, fillcolor=plum1, label="Theorem→lemma\ndependency graph"];
            Tableau     [shape=component, fillcolor=wheat, label="Tableau method"];
            NaturalDeduction [shape=component, fillcolor=wheat, label="Natural\ndeduction"];
            Resolution  [shape=hexagon, fillcolor=khaki1, label="Resolution"];
            ReductioAbsurdum [shape=ellipse, fillcolor=lightblue, label="Reductio ad\nabsurdum"];
        }

        subgraph cluster_03_verif {
            label="Verified software & formal methods"; style="dashed"; color="#4f9050";
            KFramework [shape=box3d, fillcolor=palegreen, label="K Framework"];
            PLTRedex   [shape=box3d, fillcolor=palegreen, label="PLT Redex"];
            Astree_03  [shape=box3d, fillcolor=palegreen, label="Astrée"];
            Infer_03   [shape=box3d, fillcolor=palegreen, label="Infer"];
            FramaC_03  [shape=box3d, fillcolor=palegreen, label="Frama-C"];
        }

        // Internal edges
        Lean -> DepTypes [label="implements", style=dotted, color=red];
        Coq  -> DepTypes [style=dotted, color=red];
        Agda -> DepTypes [style=dotted, color=red];
        Idris-> DepTypes [style=dotted, color=red];
        DepTypes -> TypeTheory [label="subset"];
        TypeTheory -> HoTT [label="extended by"];
        CurryHoward -> TypeTheory [label="motivates"];
        ProofTree -> ProofDAG [label="sharing makes", style=dashed, color=purple];
        Tableau -> ReductioAbsurdum [label="based on"];
        Resolution -> Prover9 [label="used by", dir=back, style=dotted, color=red];
        Resolution -> Vampire [label="used by", dir=back, style=dotted, color=red];
        Resolution -> EProver [label="used by", dir=back, style=dotted, color=red];
        ACL2 -> NaturalDeduction [style=dotted, color=red];
    }

    // =================================================================
    // 04 — Programming Languages
    // =================================================================
    subgraph cluster_04 {
        label="04 — Programming Languages";
        style="rounded,filled"; fillcolor="#fff0f5"; color="#aa3070";
        fontsize=14; fontcolor="#762048";

        subgraph cluster_04_lisp {
            label="S-expression / Lisp family"; style="dashed"; color="#cc70a0";
            Lisp     [shape=cylinder, fillcolor=pink, label="Lisp /\nCommon Lisp /\nScheme"];
            Racket   [shape=cylinder, fillcolor=pink, label="Racket"];
            Clojure  [shape=cylinder, fillcolor=pink, label="Clojure"];
            SMTLIB_lang [shape=cylinder, fillcolor=pink, label="SMT-LIB\n(as Lisp DSL)"];
        }

        subgraph cluster_04_func {
            label="Functional / typed-functional"; style="dashed"; color="#cc70a0";
            Haskell [shape=cylinder, fillcolor=pink, label="Haskell"];
            GHC     [shape=box3d, fillcolor=palegreen, label="GHC — STG /\nG-machine"];
            Scala   [shape=cylinder, fillcolor=pink, label="Scala"];
            OCaml   [shape=cylinder, fillcolor=pink, label="OCaml"];
        }

        subgraph cluster_04_scientific {
            label="Numerical / scientific hosts"; style="dashed"; color="#cc70a0";
            Julia    [shape=cylinder, fillcolor=pink, label="Julia"];
            CatlabJL [shape=box3d, fillcolor=palegreen, label="Catlab.jl"];
            Python   [shape=cylinder, fillcolor=pink, label="Python"];
            DisCoPy_04 [shape=box3d, fillcolor=palegreen, label="DisCoPy"];
        }

        subgraph cluster_04_systems {
            label="Systems / native"; style="dashed"; color="#cc70a0";
            CPP    [shape=cylinder, fillcolor=pink, label="C++"];
            Rust   [shape=cylinder, fillcolor=pink, label="Rust"];
            CLang  [shape=cylinder, fillcolor=pink, label="C"];
        }

        subgraph cluster_04_web {
            label="Web / JS ecosystem"; style="dashed"; color="#cc70a0";
            JavaScript [shape=cylinder, fillcolor=pink, label="JavaScript /\nTypeScript"];
            React      [shape=box3d,   fillcolor=palegreen, label="React"];
        }

        subgraph cluster_04_niche {
            label="Niche / categorical / experimental"; style="dashed"; color="#cc70a0";
            Globular_04   [shape=box3d, fillcolor=palegreen, label="Globular"];
            HomotopyIO_04 [shape=box3d, fillcolor=palegreen, label="Homotopy.io"];
            Quantomatic_04[shape=box3d, fillcolor=palegreen, label="Quantomatic"];
        }

        // Internal edges
        Lisp -> Racket [label="dialect", style=dashed, color=purple];
        Lisp -> Clojure [style=dashed, color=purple];
        Lisp -> SMTLIB_lang [style=dashed, color=purple];
        Haskell -> GHC [label="compiled by"];
        Julia -> CatlabJL [label="hosts"];
        Python -> DisCoPy_04 [label="hosts"];
        JavaScript -> React [label="hosts"];
    }

    // =================================================================
    // 05 — Category Theory
    // =================================================================
    subgraph cluster_05 {
        label="05 — Category Theory & Compositional Formalisms";
        style="rounded,filled"; fillcolor="#f5f0ff"; color="#5538a8";
        fontsize=14; fontcolor="#3a217a";

        subgraph cluster_05_core {
            label="Core concepts"; style="dashed"; color="#7a55cc";
            Category    [shape=ellipse, fillcolor=lightblue, label="Category\n(obj+morph)"];
            Functor     [shape=ellipse, fillcolor=lightblue, label="Functor"];
            NatTrans    [shape=ellipse, fillcolor=lightblue, label="Natural\ntransformation"];
            CommDiag    [shape=ellipse, fillcolor=lightblue, label="Commutative\ndiagram"];
            MonoidalCat [shape=ellipse, fillcolor=lightblue, label="Monoidal\ncategory"];
            HigherCat   [shape=ellipse, fillcolor=lightblue, label="Higher categories\n(2-/n-)"];
            AdhesiveCat [shape=ellipse, fillcolor=lightblue, label="Adhesive\ncategories"];
            CTLimits    [shape=ellipse, fillcolor=lightblue, label="Limits, pullbacks,\nmonomorphisms"];
        }

        subgraph cluster_05_notation {
            label="Notation / diagram languages"; style="dashed"; color="#7a55cc";
            TikZcd    [shape=parallelogram, fillcolor=lightcyan, label="TikZ-cd"];
            Quiver    [shape=parallelogram, fillcolor=lightcyan, label="Quiver"];
            Xymatrix  [shape=parallelogram, fillcolor=lightcyan, label="xymatrix"];
            Mermaid   [shape=parallelogram, fillcolor=lightcyan, label="Mermaid"];
            PlantUML  [shape=parallelogram, fillcolor=lightcyan, label="PlantUML"];
            GraphvizDOT [shape=parallelogram, fillcolor=lightcyan, label="Graphviz / DOT"];
        }

        subgraph cluster_05_string {
            label="String diagrams / process theories"; style="dashed"; color="#7a55cc";
            DisCoPy     [shape=box3d, fillcolor=palegreen, label="DisCoPy"];
            Quantomatic [shape=box3d, fillcolor=palegreen, label="Quantomatic"];
            Globular    [shape=box3d, fillcolor=palegreen, label="Globular"];
            HomotopyIO  [shape=box3d, fillcolor=palegreen, label="Homotopy.io"];
        }

        subgraph cluster_05_libs {
            label="Categorical software & libraries"; style="dashed"; color="#7a55cc";
            CatlabJL_05 [shape=box3d, fillcolor=palegreen, label="Catlab.jl"];
            AlgebraicJulia [shape=box3d, fillcolor=palegreen, label="AlgebraicJulia\necosystem"];
            HaskellAsCT [shape=ellipse, fillcolor=lightblue, label="Haskell as\n'CT language'"];
            LeanMathlibCT [shape=box3d, fillcolor=palegreen, label="Lean /\nmathlib category_theory"];
        }

        subgraph cluster_05_rewrite {
            label="Graph rewriting as categorical op"; style="dashed"; color="#7a55cc";
            DPO [shape=hexagon, fillcolor=khaki1, label="Double-pushout\n(DPO) rewriting"];
            SPO [shape=hexagon, fillcolor=khaki1, label="Single-pushout\n(SPO) rewriting"];
            TermRewriteCT [shape=ellipse, fillcolor=lightblue, label="Term rewriting\n(categorical)"];
            OperadicDSL [shape=ellipse, fillcolor=lightblue, label="Operadic DSLs"];
        }

        // Internal edges
        Category -> Functor [label="map of"];
        Functor -> NatTrans [label="map of"];
        Category -> CommDiag [label="depicted by"];
        MonoidalCat -> DisCoPy [label="modelled in", style=dotted, color=red];
        HigherCat -> Globular [label="implemented in", style=dotted, color=red];
        HigherCat -> HomotopyIO [style=dotted, color=red];
        AdhesiveCat -> DPO [label="ambient for"];
        DPO -> SPO [label="variant", style=dashed, color=purple];
        CatlabJL_05 -> AlgebraicJulia [label="anchor of"];
    }

    // =================================================================
    // 06 — Graphs & Rewrite Systems
    // =================================================================
    subgraph cluster_06 {
        label="06 — Graphs & Rewrite Systems";
        style="rounded,filled"; fillcolor="#f0fbff"; color="#306090";
        fontsize=14; fontcolor="#1f4878";

        subgraph cluster_06_basic {
            label="Basic graph kinds"; style="dashed"; color="#5588bb";
            DirGraph   [shape=folder, fillcolor=plum1, label="Directed graph"];
            DAG        [shape=folder, fillcolor=plum1, label="DAG"];
            Hypergraph [shape=folder, fillcolor=plum1, label="Hypergraph"];
            Bipartite  [shape=folder, fillcolor=plum1, label="Bipartite graph"];
            TermGraph  [shape=folder, fillcolor=plum1, label="Term graph"];
            KnowledgeGraph [shape=folder, fillcolor=plum1, label="Knowledge graph"];
            FactorGraph[shape=folder, fillcolor=plum1, label="Factor graph"];
            BayesNet   [shape=folder, fillcolor=plum1, label="Bayesian network"];
            FlowNet    [shape=folder, fillcolor=plum1, label="Flow network"];
        }

        subgraph cluster_06_equiv {
            label="Equivalence machinery"; style="dashed"; color="#5588bb";
            UnionFind  [shape=hexagon, fillcolor=khaki1, label="Union-find /\ndisjoint-set"];
            CongrClos06[shape=hexagon, fillcolor=khaki1, label="Congruence closure"];
            EquivRel   [shape=ellipse, fillcolor=lightblue, label="Equivalence relation /\nquotient structure"];
        }

        subgraph cluster_06_egraph {
            label="E-graphs & equality saturation"; style="dashed"; color="#5588bb";
            EGraph     [shape=folder, fillcolor=plum1, label="E-graph"];
            EClass     [shape=folder, fillcolor=plum1, label="E-class"];
            ENode      [shape=folder, fillcolor=plum1, label="E-node"];
            EqSat      [shape=hexagon, fillcolor=khaki1, label="Equality saturation"];
            Egg        [shape=box3d, fillcolor=palegreen, label="egg (Rust)"];
            Herbie     [shape=box3d, fillcolor=palegreen, label="Herbie"];
            Tensat     [shape=box3d, fillcolor=palegreen, label="Tensat"];
            Diospyros  [shape=box3d, fillcolor=palegreen, label="Diospyros"];
            SPORES     [shape=box3d, fillcolor=palegreen, label="SPORES"];
            EggPaper   [shape=note, fillcolor=peachpuff, label="\"egg\" paper\n(POPL 2021)"];
        }

        subgraph cluster_06_rewrite {
            label="Term & graph rewriting"; style="dashed"; color="#5588bb";
            TermRewriting [shape=hexagon, fillcolor=khaki1, label="Term rewriting"];
