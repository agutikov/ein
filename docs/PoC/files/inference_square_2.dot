digraph G {
    House, Color [style=filled];

    House-4 -> House;
    House-5 -> House;

    House-4 -> House-5 [dir=forward label="right" color="red"];

    Ivory -> Color;
    Green -> Color;

    Ivory -> Green [dir=forward label="right" color="red"];

    Ivory -> House-4;

    Green -> House-5 [style=bold color="green"];
}
