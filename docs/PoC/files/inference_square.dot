digraph G {
    House, Color, Nationality [style=filled];

    House-1 -> House;
    House-2 -> House;

    House-1 -> House-2 [label="next" color="blue"];

    Norwegian -> Nationality;

    Blue -> Color;

    Norwegian -> House-1;

    Norwegian -> Blue [label="next" color="blue"];

    Blue -> House-2 [style=bold, color="green"];

}
