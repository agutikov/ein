digraph G {
    subgraph cluster_house {
        House-1, House-2, House-3, House-4, House-5 [shape=box];
        label="House";
    }

    subgraph cluster_color {
        Ivory, Yellow, Red, Green, Blue;
        label="Color";
    }

    subgraph cluster_nation {
        Englishman, Spaniard, Ukrainian, Japanese, Norwegian;
        label="Nationality";
    }

    subgraph cluster_pet {
        Dog, Hourse, Snail, Fox, Zebra;
        label="Pet";
    }

    subgraph cluster_cigarette {
        Old_Gold, Chesterfields, Lucky_Strike, Kools, Parlament;
        label="Cigarette";
    }

    subgraph cluster_drink {
        Coffee, Milk, Tea, Juice, Water;
        label="Drink";
    }

    Englishman -> Red;
    Red -> Englishman;

    Spaniard -> Dog;
    Dog -> Spaniard;

    Coffee -> Green;
    Green -> Coffee;

    Ukrainian -> Tea;
    Tea -> Ukrainian;

    Green -> Ivory [label=<<font color="red">to the right of</font>> style=dotted color="red"];

    Old_Gold -> Snail;
    Snail -> Old_Gold;

    Kools -> Yellow;
    Yellow -> Kools;

    Milk -> House-3;
    House-3 -> Milk;

    Norwegian -> House-1;
    House-1 -> Norwegian;

    Chesterfields -> Fox [label="next to" style=dashed color="blue"];
    Fox -> Chesterfields [label="next to" style=dashed color="blue"];

    Kools -> Hourse [label="next to" style=dashed color="blue"];
    Hourse -> Kools [label="next to" style=dashed color="blue"];

    Lucky_Strike -> Juice;
    Juice -> Lucky_Strike;

    Japanese -> Parlament;
    Parlament -> Japanese;

    Norwegian -> Blue [label="next to" style=dashed color="blue"];
    Blue -> Norwegian [label="next to" style=dashed color="blue"];
}
