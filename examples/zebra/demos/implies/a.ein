;;; implies/a — right-of implies next-to (zebra's actual usage).
;;;
;;; Given:  (right-of H2 H1) + (implies right-of next-to)
;;; Derive: (next-to H2 H1)

(rules
  (rule implies (?p ?q)
    :match  (?p ?a ?b)
    :assert (?q ?a ?b)
    :why    "{?p} implies {?q}: from {?a} →{?p}→ {?b}, derive {?a} →{?q}→ {?b}."
    :priority 100))

(ontology
  (relation right-of T T)
  (relation next-to T T)
  (implies right-of next-to))

(facts
  (right-of H2 H1 :source "(1)"))
