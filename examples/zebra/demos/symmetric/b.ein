;;; symmetric/b — next-to is symmetric on house positions.
;;;
;;; Given:  (next-to House_1 House_2)
;;; Derive: (next-to House_2 House_1)

(rules
  (rule symmetric (?rel)
    :match  (?rel ?a ?b)
    :assert (?rel ?b ?a)
    :why    "{?rel} is symmetric: {?a} ↔ {?b}."
    :priority 100))

(ontology
  (relation next-to T T)
  (symmetric next-to))

(facts
  (next-to House_1 House_2 :source "demo"))
