;;; symmetric/c — friend-of is symmetric (custom domain).
;;;
;;; Given:  (friend-of Carol Dave)
;;; Derive: (friend-of Dave Carol)

(rules
  (rule symmetric (?rel)
    :match  (?rel ?a ?b)
    :assert (?rel ?b ?a)
    :why    "{?rel} is symmetric: {?a} ↔ {?b}."
    :priority 100))

(ontology
  (relation friend-of T T)
  (symmetric friend-of))

(facts
  (friend-of Carol Dave :source "demo"))
