;;; ein-bot ‚Äî branching demo 12/‚Ä¶  + S1.7.23 standing regression fixture
;;;
;;; A no-hrule, NON-`T`-typed puzzle that ACTUALLY SOLVES via the
;;; blind hypothesis enumerator (`hypgen._generate`'s no-`(hrule ‚Ä¶)`
;;; branch). It is the standing witness for retiring the kernel
;;; `is-a` type-filter ‚Äî S1.7.23 T1.7.23.1.
;;;
;;; Why it exists
;;; -------------
;;; The M1 gate (zebra2) is hrule-driven, so it never exercises the
;;; blind enumerator's `_type_compatible` type-pruning ‚Äî retiring
;;; that filter is a measured no-op there (S1.7.8 / T1.7.7.1 spike).
;;; The existing feature demos `features/04`,`05` run the blind path
;;; but abort at k=0 (non-converging), so they cannot witness a
;;; "still solves with the filter gone" regression. This puzzle does:
;;; it solves on the blind path AND its slots are real types
;;; (`House` / `Color`, never `T`), so the type-filter genuinely
;;; prunes type-wrong fillers (`type_incompatible_*` skips > 0) ‚Äî
;;; exactly the kernel mechanism S1.7.23 removes.
;;;
;;; Shape
;;; -----
;;; A 3√ó3 bijection `color-of : House ‚Üí Color` with NO positional
;;; anchors. Nothing is forced at the root, so the engine must
;;; *guess* a `(color-of H C)` (the blind enumerator's job), then
;;; the bijection machinery propagates: `functional-negative` /
;;; `injective-negative` close the row + column, `domain-elimination`
;;; forces the survivor once a house has a single colour left, and
;;; `functional` / `injective` kill any guess that collides. After
;;; two guesses + propagation a complete consistent model exists, so
;;; `solve(stop_after=1)` returns a Solution (k‚â•1). The model is not
;;; unique (a bare 3√ó3 bijection has 3! = 6 of them) ‚Äî uniqueness is
;;; NOT the point; *converging on the blind path while type-pruning*
;;; is.
;;;
;;; Once the kernel filter is retired (S1.7.23 T1.7.23.2) the blind
;;; enumerator proposes type-wrong fillers too (e.g. `(color-of Red
;;; Blue)`); `typecheck-arg-0` / `typecheck-arg-1` are the
;;; contradiction rules that then kill them. So this file also
;;; exercises that fallback.

;; ‚îÄ‚îÄ Bijection violation rules (fire `(false)` on collision) ‚îÄ‚îÄ
;; ‚îÄ‚îÄ‚îÄ std.macro (inlined copy of examples/stdlib/macro.ein) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
;; `forall` / `open` pattern macros (P1.8 S1.5.9), duplicated here until
;; ein-lang imports land (P1.8 S1.8.A1‚ÄìA5); then this block collapses to:
;;     (import std.macro :symbols (forall open))
(macro forall (?b ?G ?B)
  (absent (and ?G (absent ?B))))
(macro open (?P)
  (and (absent ?P) (absent (not ?P))))

(rule functional (?R)
  :match  (and (?R ?a ?b) (?R ?a ?c) (neq ?b ?c))
  :assert (false)
  :why    "{?R} not functional: {?a} has both {?b} and {?c}."
  :priority 250)

(rule injective (?R)
  :match  (and (?R ?a ?c) (?R ?b ?c) (neq ?a ?b))
  :assert (false)
  :why    "{?R} not injective: {?c} reached from both {?a} and {?b}."
  :priority 250)

;; ‚îÄ‚îÄ Negative-completion companions (assert the row/column nots) ‚îÄ‚îÄ
(rule functional-negative (?R)
  :match  (and (?R ?a ?b)
               (relation ?R ?A ?B)
               (is-a ?b_other ?B)
               (neq ?b_other ?b))
  :assert (not (?R ?a ?b_other))
  :why    "{?R} functional: ({?R} {?a} {?b}) ‚üπ (not ({?R} {?a} {?b_other}))."
  :priority 240)

(rule injective-negative (?R)
  :match  (and (?R ?a ?b)
               (relation ?R ?A ?B)
               (is-a ?a_other ?A)
               (neq ?a_other ?a))
  :assert (not (?R ?a_other ?b))
  :why    "{?R} injective: ({?R} {?a} {?b}) ‚üπ (not ({?R} {?a_other} {?b}))."
  :priority 240)

(rule derive-functional-negative ()
  :match  (functional ?R)
  :assert (functional-negative ?R)
  :why    "{?R} functional ‚üπ functional-negative active."
  :priority 100)

(rule derive-injective-negative ()
  :match  (injective ?R)
  :assert (injective-negative ?R)
  :why    "{?R} injective ‚üπ injective-negative active."
  :priority 100)

;; ‚îÄ‚îÄ Domain elimination (force the survivor) + no-room-left ‚îÄ‚îÄ
(rule domain-elimination (?R ?OT ?VT)
  :match  (and (functional ?R 0 1)
               (total      ?R 0)
               (is-a ?a ?OT)
               (is-a ?v ?VT)
               (forall ?v_other
                 (and (is-a ?v_other ?VT) (neq ?v_other ?v))
                 (not (?R ?a ?v_other))))
  :assert (?R ?a ?v)
  :priority 400
  :why    "every {?VT} except {?v} excluded for {?a} ‚Üí ({?R} {?a} {?v})")

(rule no-room-left (?R ?OT ?VT)
  :match  (and (functional ?R 0 1)
               (total      ?R 0)
               (is-a ?a ?OT)
               (forall ?v
                 (is-a ?v ?VT)
                 (not (?R ?a ?v))))
  :assert (false)
  :priority 110
  :why    "{?a} has every {?VT} excluded ‚Äî no value left")

;; ‚îÄ‚îÄ Closed-world type checks (the post-(b) contradiction rules) ‚îÄ‚îÄ
(rule typecheck-arg-0 (?R ?Dom)
  :match  (and (?R ?a ?b) (absent (is-a ?a ?Dom)))
  :assert (false)
  :priority 110
  :why    "{?R} arg 0 expects {?Dom}; {?a} is not a {?Dom}")

(rule typecheck-arg-1 (?R ?Ran)
  :match  (and (?R ?a ?b) (absent (is-a ?b ?Ran)))
  :assert (false)
  :priority 110
  :why    "{?R} arg 1 expects {?Ran}; {?b} is not a {?Ran}")

(relation color-of House Color)
(relation is-a     T T)

;; color-of is a bijection between House and Color.
(functional color-of)          ; violation-rule activator (2-arg)
(injective  color-of)
(functional color-of 0 1)       ; positional projection (domain-elim)
(total      color-of 0)

;; Opt color-of into elimination + the closed-world type checks.
;; `domain-elimination` is what positively *produces* a `color-of`
;; fact, so its activator also keeps `color-of` OPEN (un-`closed`)
;; for the blind enumerator ‚Äî without it `emit_closed` would close
;; `color-of` (no rule produces it) and there would be nothing to
;; guess.
(domain-elimination color-of House Color)
(no-room-left       color-of House Color)
(typecheck-arg-0    color-of House)
(typecheck-arg-1    color-of Color)

;; `is-a` is the inheritance forest ‚Äî fully given, never guessed.
;; Declare it closed so the blind enumerator only ever proposes
;; `color-of` hypotheses (the guessed relation stays open). Without
;; this the enumerator would speculate `(is-a X Y)` pairs and the
;; lattice would blow up ‚Äî the normal solve path does not auto-close
;; (that is a bench-only `emit_closed` convenience), so the fixture
;; declares it. (`color-of` is intentionally NOT closed.)
(closed is-a)

;; Type + instance hierarchy (3 houses, 3 colours).
(is-a House T) (is-a Color T)
(is-a H1 House) (is-a H2 House) (is-a H3 House)
(is-a Red Color) (is-a Green Color) (is-a Blue Color)

;; One anchor pins H1; that leaves a 2√ó2 residue (H2,H3 √ó Green,Blue)
;; that the bijection can't fully *force* without a guess ‚Äî so the
;; blind enumerator must propose `(color-of H2 ‚Ä¶)`, and `solve`
;; branches. Keeping it to a single residual guess keeps the lattice
;; tiny (fast under CPython) while still exercising the blind path.
(color-of H1 Red :source "(1) H1 is Red")

(query
  :mode solve
  :goal (color-of ?h ?c))
