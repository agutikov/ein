// P1.5b — Lattice-search per-candidate processing in layer N
//
// Render:  dot -Tsvg algorithm_layer_n.dot -o algorithm_layer_n.svg
//      or  dot -Tpng algorithm_layer_n.dot -o algorithm_layer_n.png
//
// Colour legend:
//   light blue       — setup / data flow
//   light cyan       — accumulators (forced positives / negatives)
//   light yellow     — decision points (diamonds)
//   light gray      — optional / disabled-by-default
//   pale green      — ALIVE outcome
//   medium sea green — SOLUTION outcome (terminal)
//   salmon          — DEAD outcome
//   plum            — back-propagation / nogood emission

digraph layer_n_processing {
  rankdir = TB;
  splines = polyline;
  nodesep = 0.4;
  ranksep = 0.5;
  fontname = "Helvetica";
  node [fontname = "Helvetica", shape = box, style = "rounded,filled"];
  edge [fontname = "Helvetica"];

  // ── Layer-level setup ────────────────────────────────────────────
  start [label = "Layer N start\nA_1, …, A_{N-1} frozen\nroot._nogoods carried in",
         fillcolor = lightblue];

  generate [label = "Apriori prefix-join\nA_{N-1} ⨝ A_{N-1} → candidates\n(each size-N candidate generated once)",
            fillcolor = lightblue];

  filter [label = "Filter candidates:\n• every (N-1)-subset ∈ A_{N-1}\n• ¬ matches_any_nogood(c, root._nogoods)\n• every element ∈ current_alive",
          fillcolor = lightyellow, shape = parallelogram];

  loop_head [label = "for each surviving candidate C\n(|C| = N)",
             fillcolor = lightblue, shape = octagon];

  // ── Per-candidate setup ─────────────────────────────────────────
  find_parents [label = "find C's parents:\nall N (N-1)-subsets of C\n(each must be in A_{N-1})",
                fillcolor = lightblue];

  sanity [label = "[OPTIONAL — disabled by default]\nfor each parent P_i:\n  fork(P_i.kb), add h_i = C \\ P_i, saturate\nverify state_hash(...) is identical across all i\n(validates saturation commutativity)",
          fillcolor = lightgray, style = "rounded,filled,dashed"];

  fork_one [label = "fork ANY one parent P's kb\n(commutativity ⟹ result is independent of choice)",
            fillcolor = lightblue];

  add_hyp [label = "add hypothesis h = C \\ P to fork\n(NOT yet saturated)",
           fillcolor = lightblue];

  // ── Pre-saturation contradiction (apriori filter) ───────────────
  pre_contra [label = "ContradictionDetector(fork).detect()\n[pre-sat: any (X, ¬X) pair?]",
              fillcolor = lightyellow, shape = diamond];

  // ── Saturation pipeline ─────────────────────────────────────────
  saturate [label = "Saturator(fork).saturate()",
            fillcolor = lightblue];

  // ── Post-saturation state-hash dedup ────────────────────────────
  state_hash_check [label = "state_hash(fork) ∈ lattice index?\n[post-sat dedup checkpoint]",
                    fillcolor = lightyellow, shape = diamond];

  merge_into [label = "MERGE into existing node E\n• E.labels += (C,)\n• E.parents += C's parents\n• audit row in A_N or D_N\n  marks C → merged_into=E.canonical_set\nSKIP downstream pipeline\n(verdict + bubbles already recorded on E)",
              fillcolor = lightcyan];

  record_uncond [label = "scan firings:\n• forced_positives — derives_positive ∧ ¬reaches_hypothesis\n• proposed_negatives — ¬h_other derived with no-hypothesis chain",
                 fillcolor = lightcyan];

  post_contra [label = "ContradictionDetector(fork).detect()\n[post-sat: any (X, ¬X) pair?]",
               fillcolor = lightyellow, shape = diamond];

  is_solved [label = "is_solved(fork, mode)?\n(goal facts present)",
             fillcolor = lightyellow, shape = diamond];

  // ── Outcome: ALIVE ──────────────────────────────────────────────
  alive [label = "ALIVE\nrecord SetNode in A_N\n• canonical_set = C\n• labels = (C,) (multilabel grows on future merges)\n• parents = (P_1, …, P_N)\n• kb_snapshot, firings, forced_*, learned_nogoods",
         fillcolor = palegreen];

  alive_integrate [label = "integrate(parent_kb, C's BranchResult)\nfor EACH parent P_i of C:\n• adopt forced_positives (if forced at P_i too)\n• adopt proposed_negatives (per-level unconditional check)\n• merge learned_nogoods (idempotent under subsumption)\nrecursive bubble continues until root",
                   fillcolor = plum];

  // ── Outcome: DEAD (pre-sat) ─────────────────────────────────────
  dead_pre [label = "DEAD (pre-sat)\nunsat_core = ContradictionDetector witnesses\nemit nogood = frozenset(C) into root._nogoods\nrecord SetNode in D_N with verdict=\"dead\"",
            fillcolor = salmon];

  dead_pre_integrate [label = "integrate(parent_kb, C's BranchResult)\nfor EACH parent P_i of C:\n• merge clause {frozenset(C)} into _nogoods\n(no forced positives — never saturated)\nidempotent across the N parents",
                      fillcolor = plum];

  // ── Outcome: DEAD (post-sat) ────────────────────────────────────
  dead_post [label = "DEAD (post-sat)\nunsat_core = ContradictionDetector witnesses\nemit nogood = frozenset(C) into root._nogoods\nrecord SetNode in D_N with verdict=\"dead\"",
             fillcolor = salmon];

  dead_post_integrate [label = "integrate(parent_kb, C's BranchResult)\nfor EACH parent P_i of C:\n• merge clause {frozenset(C)} into _nogoods\n• adopt forced_positives collected pre-contradiction\n  (if independently unconditional at P_i)\nidempotent across the N parents",
                       fillcolor = plum];

  // ── Outcome: SOLUTION ───────────────────────────────────────────
  solution [label = "SOLUTION\nLatticeProof produced:\n• final_kb = fork\n• alive_at_end = C\n• lattice DAG\n• dead_commitments\n(SOLVE mode: terminate; GAPS: record + continue)",
            fillcolor = mediumseagreen];

  // ── Layer wrap-up ───────────────────────────────────────────────
  loop_tail [label = "next candidate?",
             fillcolor = lightblue, shape = octagon];

  end [label = "Layer N complete\nA_N, D_N populated\nroot._nogoods updated\nrecompute current_alive for layer N+1",
       fillcolor = lightblue];

  // ── Edges: setup → loop ─────────────────────────────────────────
  start -> generate;
  generate -> filter;
  filter -> loop_head;

  // ── Edges: per-candidate ────────────────────────────────────────
  loop_head -> find_parents;
  find_parents -> sanity [style = dashed, color = gray, label = "if enabled"];
  sanity -> fork_one [style = dashed, color = gray, label = "states agree"];
  find_parents -> fork_one [label = "default path"];
  fork_one -> add_hyp;
  add_hyp -> pre_contra;

  // ── Pre-sat branch ──────────────────────────────────────────────
  pre_contra -> dead_pre [label = "contradiction", color = red];
  pre_contra -> saturate [label = "clean"];

  // ── Post-sat branch ─────────────────────────────────────────────
  saturate -> state_hash_check;
  state_hash_check -> merge_into [label = "hit", color = darkblue];
  state_hash_check -> record_uncond [label = "miss"];
  merge_into -> loop_tail [label = "skip", style = dashed, color = darkblue];
  record_uncond -> post_contra;
  post_contra -> dead_post [label = "contradiction", color = red];
  post_contra -> is_solved [label = "clean"];
  is_solved -> solution [label = "goal satisfied", color = darkgreen];
  is_solved -> alive [label = "goal not satisfied"];

  // ── Outcome → integrate ─────────────────────────────────────────
  alive -> alive_integrate;
  dead_pre -> dead_pre_integrate;
  dead_post -> dead_post_integrate;

  // ── Loop back / terminate ───────────────────────────────────────
  alive_integrate -> loop_tail;
  dead_pre_integrate -> loop_tail;
  dead_post_integrate -> loop_tail;
  solution -> loop_tail [label = "GAPS mode\nor record-and-continue", style = dotted];
  // SOLVE mode would terminate here — drawn as an implicit edge to "end" via the solution node.

  loop_tail -> loop_head [label = "more", style = dashed];
  loop_tail -> end [label = "exhausted", style = bold];

  // ── Same-rank groupings ─────────────────────────────────────────
  { rank = same; alive; dead_post; solution; }
  { rank = same; alive_integrate; dead_post_integrate; dead_pre_integrate; }
}
