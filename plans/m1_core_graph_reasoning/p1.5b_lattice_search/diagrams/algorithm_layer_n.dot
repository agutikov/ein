// P1.5b — Unified engine per-candidate processing in layer N
//
// Shared private `_explore_layers` flow used by all THREE public
// entries `monotonic_solve` + `gaps_solve` + `contradictions_solve`
// (all sibling functions in inference/monotonic/solver.py — one
// unified engine, three contracts). Entry-specific behaviour is
// annotated at the outcome nodes (record_solution, dead_collect):
// monotonic adds early-terminate at record_solution; gaps + contra
// always exhaust and collect.
//
// Saturation commutativity + flat root-writes kill the per-parent
// bubble + per-set kb storage of ALIVE intermediates that earlier
// drafts of this diagram carried. See algorithm_layer_n.md for the
// per-step contract; see project_set_search_unified memory +
// 2026-05-28 conversation for the rationale.
//
// Render:  dot -Tsvg algorithm_layer_n.dot -o algorithm_layer_n.svg
//      or  dot -Tpng algorithm_layer_n.dot -o algorithm_layer_n.png
//
// Colour legend:
//   light blue       — setup / data flow / try_commitment_set
//   light yellow     — decision points (diamonds)
//   light gray       — optional / opt-in feature (hash dedup, sanity)
//   pale green       — ALIVE outcome
//   medium sea green — SOLUTION outcome (entry-specific: collected by gaps_solve)
//   salmon           — DEAD outcome (nogood emit + entry-specific: collected by contradictions_solve)
//   plum             — root-mutation step (flat write: nogoods or unconditional facts)

digraph layer_n_processing {
  rankdir = TB;
  splines = polyline;
  nodesep = 0.4;
  ranksep = 0.5;
  fontname = "Helvetica";
  node [fontname = "Helvetica", shape = box, style = "rounded,filled"];
  edge [fontname = "Helvetica"];

  // ── Layer-level setup ──────────────────────────────────────────
  start [label = "Layer N start\nA_1, …, A_{N-1} frozen\nroot.facts + root._nogoods current",
         fillcolor = lightblue];

  generate [label = "Apriori prefix-join\nA_{N-1} ⨝ A_{N-1} → candidates\n(each size-N candidate generated once)",
            fillcolor = lightblue];

  filter [label = "Filter candidates:\n• every (N-1)-subset ∈ A_{N-1}\n• ¬ matches_any_nogood(C, root._nogoods)\n• every element ∈ current_alive",
          fillcolor = lightyellow, shape = parallelogram];

  loop_head [label = "for each surviving candidate C\n(|C| = N)",
             fillcolor = lightblue, shape = octagon];

  // ── Per-candidate setup ────────────────────────────────────────
  try_set [label = "try_commitment_set(root, C):\n• fork ← root.fork()\n• add every h ∈ C to fork\n• pre-sat ContradictionDetector(fork)\n• Saturator(fork).saturate()\n• post-sat ContradictionDetector(fork)\n• extract unconditional_facts (chain ∩ C = ∅)",
           fillcolor = lightblue];

  hash_dedup [label = "[OPT-IN — store_lattice flag]\nstate_hash(fork) ∈ proof.kb_index?\n[under gaps_solve: SetNode is added but\n NOT merged — distinct sets must register\n separately by GAPS contract]",
              fillcolor = lightgray, style = "rounded,filled,dashed", shape = diamond];

  merge_label [label = "MERGE label into existing SetNode E\n(contradictions_solve only):\n• E.labels += (C,)\n• audit row marks C → merged_into = E\nSKIP downstream (everything already recorded)",
               fillcolor = lightgray, style = "rounded,filled,dashed"];

  kind_check [label = "result.kind?",
              fillcolor = lightyellow, shape = diamond];

  // ── DEAD path ──────────────────────────────────────────────────
  dead [label = "DEAD (pre-sat or post-sat)\nunsat_core = result.unsat_core",
        fillcolor = salmon];

  dead_root_write [label = "Flat root-write:\n• emit_nogood(root, frozenset(C))\n  (subsumption-aware insert — nogoods.py)\n• if |C| = 1: write (not h) to root._negated_facts\n  (+ symmetric mirror if applicable)",
                   fillcolor = plum];

  dead_collect [label = "[contradictions_solve only]\nproof.dead_commitments.append(\n  DeadCommitment(C, unsat_core, ...)\n)\n[gaps_solve / monotonic_solve:\n nothing collected; clause suffices]",
                fillcolor = lightcyan];

  // ── ALIVE path ─────────────────────────────────────────────────
  is_solved_fork [label = "is_solved(result.kb, mode)?",
                  fillcolor = lightyellow, shape = diamond];

  record_solution [label = "RECORD solution (entry-specific):\n• gaps_solve:\n    proof.solutions.append(\n      SolutionRecord(C, result.kb.snapshot(), ...)\n    )\n• monotonic_solve:\n    return Solution(kb=result.kb)   ← early-terminate\n• contradictions_solve: nothing recorded",
                   fillcolor = mediumseagreen];

  merge_uncond [label = "Flat root-write (alive merge):\n• for f ∈ result.unconditional_facts:\n    root.add_fact(f); root._index_fact(f)\n• Saturator(root).saturate()\n• ContradictionDetector(root) — early ⊥ exit\n• alive ← compute_alive(root)\n• promote_forced_positives cascade\n  (singleton alive → h is forced)\n• if is_solved(root): entry-specific record\n  (monotonic terminates; gaps records; contra: nothing)",
                fillcolor = plum];

  // ── Layer wrap-up ──────────────────────────────────────────────
  loop_tail [label = "next candidate?",
             fillcolor = lightblue, shape = octagon];

  end [label = "Layer N complete\nA_N populated (alive sets visited)\nroot.facts + root._nogoods up to date\nproof.solutions + proof.dead_commitments grown",
       fillcolor = lightblue];

  // ── Edges: setup → loop ────────────────────────────────────────
  start -> generate;
  generate -> filter;
  filter -> loop_head;

  // ── Per-candidate edges ────────────────────────────────────────
  loop_head -> try_set;
  try_set -> hash_dedup [label = "if flag on", style = dashed, color = gray];
  try_set -> kind_check [label = "default"];
  hash_dedup -> merge_label [label = "hit (cross-set collide)", style = dashed, color = gray];
  hash_dedup -> kind_check [label = "miss"];
  merge_label -> loop_tail [style = dashed, color = gray];

  kind_check -> dead [label = "dead-pre / dead-post", color = red];
  kind_check -> is_solved_fork [label = "alive"];

  // ── DEAD subgraph ──────────────────────────────────────────────
  dead -> dead_root_write;
  dead_root_write -> dead_collect;
  dead_collect -> loop_tail;

  // ── ALIVE subgraph ─────────────────────────────────────────────
  is_solved_fork -> record_solution [label = "goal satisfied", color = darkgreen];
  is_solved_fork -> merge_uncond [label = "goal not satisfied"];
  record_solution -> loop_tail [label = "gaps/contra: continue", color = darkgreen];
  // monotonic_solve's early-terminate is an implicit edge out of
  // record_solution to the solver's exit — not shown here since
  // this diagram describes the lattice engine's shared core.
  merge_uncond -> loop_tail;

  // ── Loop back / terminate ──────────────────────────────────────
  loop_tail -> loop_head [label = "more", style = dashed];
  loop_tail -> end [label = "exhausted", style = bold];

  // ── Same-rank groupings ────────────────────────────────────────
  { rank = same; dead; is_solved_fork; }
  { rank = same; dead_root_write; record_solution; merge_uncond; }
  { rank = same; dead_collect; }
}
