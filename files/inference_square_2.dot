digraph G {
    House, Color [style=filled];

    House_4 -> House;
    House_5 -> House;

    House_4 -> House_5 [dir=forward label="right" color="red"];

    Ivory -> Color;
    Green -> Color;

    Ivory -> Green [dir=forward label="right" color="red"];

    Ivory -> House_4;

    Green -> House_5 [style=bold color="green"];
}
