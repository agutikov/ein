// ein-bot IR — kernel grammar
// Designed in S1.1.1 T1.1.1.1 + T1.1.1.2.
// See plans/m1_core_graph_reasoning/p1.1_ir_language/s1.1.1_grammar_design.md
//
// LEVEL B — structurally typed kernel, generic interiors.
//
// Enforced by the grammar:
//   1. Top level: exactly 7 reserved heads
//      ontology · facts · reasoning · rules · query · trace · config
//   2. Inside (ontology …): the `relation` schema declarator PLUS
//                           any fact shape — the ontology layer
//                           holds implicit assumptions (type /
//                           instance enumerations, rule-application
//                           facts, structural facts derived from
//                           background context). Per plans/README.md
//                           glossary. `type` / `instance` are plain
//                           facts since S1.7.6 — not kernel
//                           declarators.
//   3. Inside (facts …):    explicit problem statements only —
//                           `=`, `not`, plus generic (NAME args*)
//                           forms for relation assertions (an
//                           `(instance …)` enumeration is just one
//                           such generic fact). Each carries
//                           `:source "(N)"` pointing at the puzzle
//                           condition.
//   4. Inside (reasoning …): derived facts the engine has inferred
//                           at runtime. Same fact shapes as (facts);
//                           provenance is `:rule` / `:using` instead
//                           of `:source`. Authors usually leave this
//                           block empty; the engine dumps it after a
//                           solve.
//   5. Inside (trace …):    only step · branch-open · branch-close ·
//                           contradiction · symmetry-class
//   6. :keyword value pair alternation — KEYWORD is never a value,
//      never appears twice in a row.
//   7. Heads of expression lists (inside values and patterns) must be
//      SYMBOL, VAR, WILDCARD, or "=" — never KEYWORD. (?var :key :key)
//      still fails via the kw_pair production, not via head restriction.
//   8. **Kernel meta-primitives are reserved words** (shape-pinned):
//      · `not`      — (not EXPR)                     — negation
//      · `and`      — (and EXPR+ [kw_pair*])         — conjunction
//      · `or`       — (or  EXPR+ [kw_pair*])         — disjunction
//      · `neq`      — (neq A B)                      — distinctness predicate
//      · `relation` — (relation NAME T1 T2 … [kw…])  — schema declarator (R10)
//      These never match SYMBOL — a typo like `(nto Foo)` for
//      `(not Foo)` is a parse-time error, not a validator error.
//      Similarly `(relation R (T1 T2))` is rejected: the inner group
//      has no matching production in relation_decl, and `relation` no
//      longer falls back to generic_fact.
//      `(symmetric R)`, `(transitive R)` etc. stay generic because
//      they ARE declared (as rules) in the puzzle file. So do `type` /
//      `instance` (S1.7.6): they are ordinary relations declared in
//      the puzzle, not kernel forms.
//
// Domain-relation heads (`co-located`, `lives-in`, …) stay generic:
// they are declared via `(relation …)` in the ontology.
//
// Rule parameter lists are MANDATORY: `()` for non-generic rules,
// `(?p1 ?p2 …)` for generic rules.
//
// Deferred to the semantic validator (S1.1.2):
//   · which keywords are required per form (:match/:assert/:why in
//     rules; :rule/:using/:derives in steps; :mode/:goal in query)
//   · the named structural-predicate registry (A.4 closure)
//   · arity rules, ground-vs-pattern, type-checking of instance args,
//     unbound-variable checks, etc.
//
// This is the source of truth for the kernel shape. M2's GBNF for
// constrained LLM decoding is derived from this file by a Lark→GBNF
// translator (utils/lark_to_gbnf.py, planned for M2.P2.3).

start: form*

?form: ontology_form
     | facts_form
     | reasoning_form
     | rules_form
     | query_form
     | trace_form
     | config_form

// ═══════════ Ontology (schema + implicit assumptions) ═══════════
// `relation` takes flat args under M1 form (b)
// (kernel docs `01-ein-graph/03_ein_model.md` §7.2; P1.3 S1.3.0 R10).
// `(relation R (T1 T2))` is rejected — the inner group has no purpose
// when no body follows. Token disambiguation works because trailing
// `:kw value` pairs lex as KEYWORD, not SYMBOL.
ontology_form: "(" "ontology" ontology_decl* ")"
?ontology_decl: relation_decl
              | fact_form
relation_decl: "(" "relation" SYMBOL SYMBOL+ kw_pair* ")"

// ═══════════ Facts (explicit problem statements) ═══════════
// `fact_form` is shared with (ontology …) and (reasoning …); the
// block name carries the provenance distinction (explicit / implicit
// / derived). `(type …)` / `(instance …)` enumerations parse here as
// ordinary generic_fact forms (S1.7.6 — no longer kernel declarators).
facts_form: "(" "facts" fact_form* ")"
?fact_form: eq_fact | not_form | generic_fact
eq_fact:      "(" EQ value value kw_pair* ")"
generic_fact: "(" SYMBOL value* kw_pair* ")"

// ═══════════ Reasoning (derived facts; engine working memory) ═══════════
reasoning_form: "(" "reasoning" fact_form* ")"

// ═══════════ Rules ═══════════
// `hrule` (S1.5.6b) — a *hypothesis rule*: same shape as `rule`,
// lives in the (rules …) block, but loaded into kb.hrules (not
// kb.rules) — its conclusions are speculative candidates, not
// entailed facts. The saturator never fires it.
rules_form: "(" "rules" (rule_decl | hrule_decl)* ")"
rule_decl:  "(" "rule"  SYMBOL rule_params kw_pair+ ")"
hrule_decl: "(" "hrule" SYMBOL rule_params kw_pair+ ")"
rule_params: "(" VAR* ")"

// ═══════════ Query ═══════════
query_form: "(" "query" kw_pair+ ")"

// ═══════════ Config (solver-level knobs) — T1.5.4.4 ═══════════
// Empty body is valid: `(config)` resolves to `SolverConfig()`
// (all defaults). Each `:flag value` pair toggles one boolean
// gate per `SolverConfig` field; values are SYMBOL `true` / `false`.
config_form: "(" "config" kw_pair* ")"

// ═══════════ Trace ═══════════
trace_form: "(" "trace" trace_event* ")"
?trace_event: step_decl
            | branch_open
            | branch_close
            | branch_ref
            | contradiction_decl
            | symmetry_decl
step_decl:          "(" "step" SYMBOL kw_pair* ")"
branch_open:        "(" "branch-open" SYMBOL kw_pair* ")"
branch_close:       "(" "branch-close" SYMBOL kw_pair* ")"
branch_ref:         "(" "branch-ref" SYMBOL ")"
contradiction_decl: "(" "contradiction" SYMBOL kw_pair* ")"
symmetry_decl:      "(" "symmetry-class" SYMBOL kw_pair* ")"

// ═══════════ Value sub-language (interior of kw_pair) ═══════════
// Values never include KEYWORD — that's what enforces :kw value pair
// alternation. List heads in the pattern interior are restricted to
// SYMBOL / WILDCARD / "=" so VAR / KEYWORD can never be a head.
//
// Reserved-word forms (not · and · or · neq) are matched BEFORE
// generic_list — their literal heads beat SYMBOL at the lexer
// (anonymous string literals have higher priority than the SYMBOL
// regex), so the generic_list alternative cannot match them.
// `(instance …)` is no longer reserved (S1.7.6): it parses as a
// generic_list whose head atom is `instance`.
kw_pair: KEYWORD value
?value: not_form
      | and_form
      | or_form
      | neq_form
      | generic_list
      | SYMBOL | VAR | WILDCARD | INT | RANGE | STRING
generic_list: "(" ")"
            | "(" list_head list_item* ")"
?list_head: SYMBOL | VAR | WILDCARD | EQ
?list_item: value | kw_pair

// ═══════════ Kernel meta-primitives (shape-pinned) ═══════════
// `not` accepts trailing kw_pairs so derived-fact provenance (e.g.
// `:rule type-exclusivity :using (c10)`) attaches naturally inside
// (reasoning …). In :match / :assert positions the validator will
// reject unwanted kw_pairs.
not_form:      "(" "not" value kw_pair* ")"
neq_form:      "(" "neq" value value ")"
and_form:      "(" "and" value+ kw_pair* ")"
or_form:       "(" "or" value+ kw_pair* ")"

// ═══════════ Terminals ═══════════
// SYMBOL excludes the kernel-primitive reserved words via a negative
// lookahead with a word boundary — `(neq …)` is reserved, but
// `neq_test` is still a valid SYMBOL. `instance` left the reserved
// set in S1.7.6 (it is now a plain relation), so `(instance Norwegian)`
// no longer gets parse-time arity rejection — it parses as a generic
// fact with one arg, like any domain head.
SYMBOL:   /(?!(?:not|and|or|neq)\b)[A-Za-z][A-Za-z0-9_*-]*/
VAR:      /\?[A-Za-z][A-Za-z0-9_*-]*/
KEYWORD:  /:[a-z][A-Za-z0-9_-]*/
WILDCARD: "_"
EQ:       "="
RANGE:    /[0-9]+\.\.([0-9]+|\*)/
INT:      /-?[0-9]+/
STRING:   /"([^"\\]|\\.)*"/

LINE_COMMENT:  /;[^\n]*/
BLOCK_COMMENT: /#\|[\s\S]*?\|#/
%ignore LINE_COMMENT
%ignore BLOCK_COMMENT
%ignore /\s+/
