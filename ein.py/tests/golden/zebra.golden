(rule
  symmetric
  (?rel)
  :match (?rel ?a ?b)
  :assert (?rel ?b ?a)
  :why "{?rel} is symmetric: {?a} ↔ {?b}."
  :priority 100)

(rule
  transitive
  (?rel)
  :match (and (?rel ?a ?b) (?rel ?b ?c) (neq ?a ?c))
  :assert (?rel ?a ?c)
  :why "{?rel} is transitive: {?a} →{?rel}→ {?b} →{?rel}→ {?c}."
  :priority 200)

(rule
  implies
  (?p ?q)
  :match (?p ?a ?b)
  :assert (?q ?a ?b)
  :why "{?p} implies {?q}: from {?a} →{?p}→ {?b}, derive {?a} →{?q}→ {?b}."
  :priority 100)

(rule
  square-fwd
  (?R)
  :match (and (?R ?a ?b) (?R ?x ?y) (co-located ?a ?x))
  :assert (co-located ?b ?y)
  :why "square ({?R}, fwd): {?a}↔{?x} bridges {?b}↔{?y}."
  :priority 200)

(rule
  square-bwd
  (?R)
  :match (and (?R ?a ?b) (?R ?x ?y) (co-located ?b ?y))
  :assert (co-located ?a ?x)
  :why "square ({?R}, bwd): {?b}↔{?y} bridges {?a}↔{?x}."
  :priority 200)

(rule
  square-unique
  (?R ?T)
  :match (and (?R ?a ?b) (?R ?x ?y) (instance ?x ?T) (co-located ?a ?x) (absent (and (?R ?x ?z) (neq ?y ?z))))
  :assert (co-located ?b ?y)
  :why "{?x} (an {?T}) has only {?y} as {?R}-neighbour; {?a}↔{?x} carries {?b}↔{?y}."
  :priority 200)

(rule
  type-exclusivity
  (?R)
  :match (and (instance ?a ?T) (instance ?b ?T) (neq ?a ?b))
  :assert (not (?R ?a ?b))
  :why "{?a} and {?b} are distinct instances of {?T} — exclusive under {?R}."
  :priority 300)

(rule
  hypothesis-contradiction
  ()
  :match (and (hypothesis ?h) (contradiction-under ?h))
  :assert (not ?h)
  :why "Assumed {?h}; branch derived a contradiction. Therefore (not {?h})."
  :priority 900)

(relation type T T)

(relation instance T T)

(relation co-located Attribute Attribute)

(relation right-of Attribute Attribute)

(relation next-to Attribute Attribute)

(symmetric co-located)

(transitive co-located)

(symmetric next-to)

(implies right-of next-to)

(square-fwd right-of)

(square-bwd right-of)

(square-unique next-to House)

(type-exclusivity co-located)

