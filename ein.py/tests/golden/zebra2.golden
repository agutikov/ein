  (typecheck-arg-1 house-nation Nationality)
  (typecheck-arg-0 house-drink House)
  (typecheck-arg-1 house-drink Drink)
  (typecheck-arg-0 house-smoke House)
  (typecheck-arg-1 house-smoke Cigarette)
  (typecheck-arg-0 house-pet House)
  (typecheck-arg-1 house-pet Pet)
  (domain-elimination house-color House Color)
  (domain-elimination house-nation House Nationality)
  (domain-elimination house-drink House Drink)
  (domain-elimination house-smoke House Cigarette)
  (domain-elimination house-pet House Pet)
  (no-room-left house-color House Color)
  (no-room-left house-nation House Nationality)
  (no-room-left house-drink House Drink)
  (no-room-left house-smoke House Cigarette)
  (no-room-left house-pet House Pet)
  (is-a Attribute T)
  (is-a House Attribute)
  (is-a Color Attribute)
  (is-a Nationality Attribute)
  (is-a Pet Attribute)
  (is-a Cigarette Attribute)
  (is-a Drink Attribute)
  (is-a House_1 House)
  (is-a House_2 House)
  (is-a House_3 House)
  (is-a House_4 House)
  (is-a House_5 House)
  (is-a Red Color)
  (is-a Green Color)
  (is-a Ivory Color)
  (is-a Yellow Color)
  (is-a Blue Color)
  (is-a Englishman Nationality)
  (is-a Spaniard Nationality)
