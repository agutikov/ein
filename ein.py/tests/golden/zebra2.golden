(config :enable-pre-branch-lookahead true)

(import std.algebra :symbols (symmetric transitive includes))

(import
  std.bijection
  :symbols (bijective-properties bijective-setup typecheck-setup))

(bijection-hierarchy is-a)

(typecheck-hierarchy is-a*)

(rule
  co-located
  (?R1 ?V1 ?R2 ?V2)
  :match (?R1 ?V1 ?h)
  :assert (?R2 ?V2 ?h)
  :why "co-located: ({?R1} {?V1} {?h}) ⟹ ({?R2} {?V2} {?h})."
  :priority 200)

(rule
  co-located-fanout
  ()
  :match (co-located ?R1 ?V1 ?R2 ?V2)
  :assert (and (co-located ?R2 ?V2 ?R1 ?V1) (co-located-negative ?R1 ?V1 ?R2 ?V2))
  :why "co-located {?R1} {?V1} ↔ {?R2} {?V2}: derive the reverse (symmetry) + negative-propagation activators."
  :priority 100)

(rule
  co-located-negative
  (?R1 ?V1 ?R2 ?V2)
  :match (not (?R1 ?V1 ?h))
  :assert (not (?R2 ?V2 ?h))
  :why "co-located: (not ({?R1} {?V1} {?h})) ⟹ (not ({?R2} {?V2} {?h}))."
  :priority 200)

(rule
  adjacent-via-fwd
  (?S ?R1 ?V1 ?R2 ?V2)
  :match (and (?R1 ?V1 ?h1) (?S ?h2 ?h1) (absent (and (?S ?h_o ?h1) (neq ?h_o ?h2))))
  :assert (?R2 ?V2 ?h2)
  :why "({?R1} {?V1} {?h1}) and unique-{?S} neighbour {?h2} ⟹ ({?R2} {?V2} {?h2})."
  :priority 200)

(rule
  adjacent-via-bwd
  (?S ?R1 ?V1 ?R2 ?V2)
  :match (and (?R2 ?V2 ?h2) (?S ?h2 ?h1) (absent (and (?S ?h2 ?h_o) (neq ?h_o ?h1))))
  :assert (?R1 ?V1 ?h1)
  :why "({?R2} {?V2} {?h2}) with unique-{?S}⁻¹ {?h1} ⟹ ({?R1} {?V1} {?h1})."
  :priority 200)

(rule
  adjacent-via-fwd-negative
  (?S ?R1 ?V1 ?R2 ?V2)
  :match (and (not (?R2 ?V2 ?h2)) (?S ?h2 ?h1) (absent (and (?S ?h_o ?h1) (neq ?h_o ?h2))))
  :assert (not (?R1 ?V1 ?h1))
  :why "(not ({?R2} {?V2} {?h2})) + unique-{?S}-source {?h1} ⟹ (not ({?R1} {?V1} {?h1}))."
  :priority 240)

(rule
  adjacent-via-bwd-negative
  (?S ?R1 ?V1 ?R2 ?V2)
  :match (and (not (?R1 ?V1 ?h1)) (?S ?h2 ?h1) (absent (and (?S ?h2 ?h_o) (neq ?h_o ?h1))))
  :assert (not (?R2 ?V2 ?h2))
  :why "(not ({?R1} {?V1} {?h1})) + unique-{?S}-target {?h2} ⟹ (not ({?R2} {?V2} {?h2}))."
  :priority 240)

(rule
  derive-adjacent-via
  ()
  :match (adjacent-via ?S ?R1 ?V1 ?R2 ?V2)
  :assert (and (adjacent-via-fwd ?S ?R1 ?V1 ?R2 ?V2) (adjacent-via-bwd ?S ?R1 ?V1 ?R2 ?V2))
  :why "adjacent-via ⟹ both directional activators (identical args)."
  :priority 100)

(rule
  derive-adjacent-via-fwd-fanout
  ()
  :match (adjacent-via-fwd ?S ?R1 ?V1 ?R2 ?V2)
  :assert (and (adjacent-via-fwd-negative ?S ?R1 ?V1 ?R2 ?V2) (disjunctive-prune-fwd ?S ?R1 ?V1 ?R2 ?V2) (adjacent-via-endpoint-fwd ?S ?R1 ?V1 ?R2 ?V2))
  :why "adjacent-via-fwd ⟹ its negative / disjunctive-prune / endpoint activators."
  :priority 200)

(rule
  derive-adjacent-via-bwd-fanout
  ()
  :match (adjacent-via-bwd ?S ?R1 ?V1 ?R2 ?V2)
  :assert (and (adjacent-via-bwd-negative ?S ?R1 ?V1 ?R2 ?V2) (disjunctive-prune-bwd ?S ?R1 ?V1 ?R2 ?V2) (adjacent-via-endpoint-bwd ?S ?R1 ?V1 ?R2 ?V2))
  :why "adjacent-via-bwd ⟹ its negative / disjunctive-prune / endpoint activators."
  :priority 200)

(rule
  disjunctive-prune-fwd
  (?S ?R1 ?V1 ?R2 ?V2)
  :match (and (?R1 ?V1 ?h1) (relation ?R2 ?A ?B) (is-a ?h_other ?B) (neq ?h_other ?h1) (absent (?S ?h_other ?h1)))
  :assert (not (?R2 ?V2 ?h_other))
  :why "({?V1} at {?h1} via {?R1}) restricts {?V2} to {?S}-neighbours (fwd); {?h_other} excluded."
  :priority 250)

(rule
  disjunctive-prune-bwd
  (?S ?R1 ?V1 ?R2 ?V2)
  :match (and (?R2 ?V2 ?h1) (relation ?R1 ?A ?B) (is-a ?h_other ?B) (neq ?h_other ?h1) (absent (?S ?h1 ?h_other)))
  :assert (not (?R1 ?V1 ?h_other))
  :why "({?V2} at {?h1} via {?R2}) restricts {?V1} to {?S}-preimages (bwd); {?h_other} excluded."
  :priority 250)

(rule
  adjacent-via-endpoint-fwd
  (?S ?R1 ?V1 ?R2 ?V2)
  :match (and (relation ?R1 ?A ?B) (is-a ?h1 ?B) (absent (and (is-a ?h2 ?B) (?S ?h2 ?h1))))
  :assert (not (?R1 ?V1 ?h1))
  :why "{?h1} has no {?S}-source; ({?R1} {?V1} {?h1}) impossible."
  :priority 240)

(rule
  adjacent-via-endpoint-bwd
  (?S ?R1 ?V1 ?R2 ?V2)
  :match (and (relation ?R2 ?A ?B) (is-a ?h2 ?B) (absent (and (is-a ?h1 ?B) (?S ?h2 ?h1))))
  :assert (not (?R2 ?V2 ?h2))
  :why "{?h2} has no {?S}-target; ({?R2} {?V2} {?h2}) impossible."
  :priority 240)

(hrule
  guess
  (?R ?T1 ?T2)
  :match (and (is-a ?a ?T1) (is-a ?b ?T2))
  :assert (?R ?a ?b)
  :why "guess: ({?R} {?a} {?b})?")

(relation is-a T T)

(relation is-a* T T)

(relation color-loc Color House :why "{?2} is painted {?1}")

(relation nation-loc Nationality House :why "the {?1} lives in {?2}")

(relation drink-loc Drink House :why "{?1} is drunk in {?2}")

(relation smoke-loc Cigarette House :why "{?1} is smoked in {?2}")

(relation pet-loc Pet House :why "the {?1} is kept in {?2}")

(relation right-of House House)

(relation next-to House House)

(includes is-a is-a*)

(transitive is-a*)

(symmetric next-to)

(includes right-of next-to)

(bijective color-loc)

(bijective nation-loc)

(bijective drink-loc)

(bijective smoke-loc)

(bijective pet-loc)

(is-a Attribute T)

(is-a House Attribute)

(is-a Color Attribute)

