(config :enable-pre-branch-lookahead true)

(rules
  (rule
    symmetric
    (?rel)
    :match (?rel ?a ?b)
    :assert (?rel ?b ?a)
    :why "{?rel} is symmetric: {?a} ↔ {?b}."
    :priority 100)
  (rule
    transitive
    (?rel)
    :match (and (?rel ?a ?b) (?rel ?b ?c) (neq ?a ?c))
    :assert (?rel ?a ?c)
    :why "{?rel} is transitive."
    :priority 200)
  (rule
    includes
    (?p ?q)
    :match (?p ?a ?b)
    :assert (?q ?a ?b)
    :why "{?q} includes {?p}: from {?a} →{?p}→ {?b}, derive {?a} →{?q}→ {?b}."
    :priority 100)
  (rule
    asymmetric
    (?rel)
    :match (and (?rel ?a ?b) (neq ?a ?b))
    :assert (not (?rel ?b ?a))
    :why "{?rel} is asymmetric: ¬({?b} →{?rel}→ {?a})."
    :priority 100)
  (rule
    sibling-exclusive
    (?siblings-via ?exclusive-under)
    :match (and (?siblings-via ?a ?P) (?siblings-via ?b ?P) (neq ?a ?b))
    :assert (not (?exclusive-under ?a ?b))
    :why "{?a} and {?b} share parent {?P} under {?siblings-via}; exclusive under {?exclusive-under}."
    :priority 300)
  (rule
    functional
    (?R)
    :match (and (?R ?a ?b) (?R ?a ?c) (neq ?b ?c))
    :assert (false)
    :why "{?R} not functional: {?a} has both {?b} and {?c}."
    :priority 250)
  (rule
    injective
    (?R)
    :match (and (?R ?a ?c) (?R ?b ?c) (neq ?a ?b))
    :assert (false)
    :why "{?R} not injective: {?c} reached from both {?a} and {?b}."
    :priority 250)
  (rule
    linked
    (?R1 ?V1 ?R2 ?V2)
    :match (?R1 ?h ?V1)
    :assert (?R2 ?h ?V2)
    :why "linked: ({?R1} {?h} {?V1}) ⟹ ({?R2} {?h} {?V2})."
    :priority 200)
  (rule
    linked-symmetric
    ()
    :match (linked ?R1 ?V1 ?R2 ?V2)
    :assert (linked ?R2 ?V2 ?R1 ?V1)
    :why "linked is symmetric: derive reverse activator."
    :priority 100)
  (rule
    cross-attr-spatial-fwd
    (?R1 ?V1 ?R2 ?V2 ?S)
    :match (and (?R1 ?h1 ?V1) (?S ?h2 ?h1) (absent (and (?S ?h_o ?h1) (neq ?h_o ?h2))))
    :assert (?R2 ?h2 ?V2)
    :why "({?R1} {?h1} {?V1}) and unique-{?S} neighbour {?h2} ⟹ ({?R2} {?h2} {?V2})."
    :priority 200)
  (rule
    cross-attr-spatial-bwd
    (?R1 ?V1 ?R2 ?V2 ?S)
    :match (and (?R2 ?h2 ?V2) (?S ?h2 ?h1) (absent (and (?S ?h2 ?h_o) (neq ?h_o ?h1))))
    :assert (?R1 ?h1 ?V1)
    :why "({?R2} {?h2} {?V2}) with unique-{?S}⁻¹ {?h1} ⟹ ({?R1} {?h1} {?V1})."
    :priority 200)
  (rule
    disjunctive-prune
    (?R1 ?V1 ?R2 ?V2 ?S)
    :match (and (?R1 ?h1 ?V1) (relation ?R2 ?A ?B) (is-a ?h_other ?A) (neq ?h_other ?h1) (absent (?S ?h_other ?h1)))
    :assert (not (?R2 ?h_other ?V2))
    :why "({?V1} at {?h1} via {?R1}) restricts {?V2} to {?S}-neighbours; {?h_other} excluded."
    :priority 250)
  (rule
    derive-disjunctive-prune-fwd
    ()
    :match (cross-attr-spatial-fwd ?R1 ?V1 ?R2 ?V2 ?S)
    :assert (disjunctive-prune ?R1 ?V1 ?R2 ?V2 ?S)
    :why "cross-attr-spatial-fwd ⟹ disjunctive-prune (same direction)."
    :priority 200)
  (rule
    derive-disjunctive-prune-bwd
    ()
    :match (cross-attr-spatial-bwd ?R1 ?V1 ?R2 ?V2 ?S)
    :assert (disjunctive-prune ?R2 ?V2 ?R1 ?V1 ?S)
    :why "cross-attr-spatial-bwd ⟹ disjunctive-prune (swapped sides)."
    :priority 200)
  (rule
    typecheck-arg-0
    (?R ?Dom)
    :match (and (?R ?a ?b) (absent (is-a* ?a ?Dom)))
    :assert (false)
    :why "{?R} arg 0 expects {?Dom}; {?a} is not a {?Dom}."
    :priority 220)
  (rule
    typecheck-arg-1
    (?R ?Ran)
    :match (and (?R ?a ?b) (absent (is-a* ?b ?Ran)))
    :assert (false)
    :why "{?R} arg 1 expects {?Ran}; {?b} is not a {?Ran}."
    :priority 220)
  (rule
    domain-elimination
    (?R)
    :match (and (functional ?R) (total ?R) (relation ?R ?A ?B) (is-a ?a ?A) (is-a ?b ?B) (forall ?b_other (and (is-a ?b_other ?B) (neq ?b_other ?b)) (not (?R ?a ?b_other))))
    :assert (?R ?a ?b)
    :why "every {?B} except {?b} excluded for {?a} → ({?R} {?a} {?b})."
    :priority 400)
  (rule
    range-elimination
    (?R)
    :match (and (injective ?R) (surjective ?R) (relation ?R ?A ?B) (is-a ?b ?B) (is-a ?a ?A) (forall ?a_other (and (is-a ?a_other ?A) (neq ?a_other ?a)) (not (?R ?a_other ?b))))
    :assert (?R ?a ?b)
    :why "every {?A} except {?a} excluded for {?b} → ({?R} {?a} {?b})."
    :priority 400)
  (rule
    total
    (?R)
    :match (and (relation ?R ?A ?B) (is-a ?a ?A) (forall ?b (is-a ?b ?B) (not (?R ?a ?b))))
    :assert (false)
    :why "{?R} not total at {?a}: every {?B} is excluded."
    :priority 110)
  (rule
    surjective
    (?R)
    :match (and (relation ?R ?A ?B) (is-a ?b ?B) (forall ?a (is-a ?a ?A) (not (?R ?a ?b))))
    :assert (false)
    :why "{?R} not surjective at {?b}: every {?A} is excluded."
    :priority 110)
  (rule
    bijective-functional
    ()
    :match (bijective ?R)
    :assert (functional ?R)
    :why "{?R} is bijective ⟹ functional."
    :priority 100)
  (rule
    bijective-injective
    ()
    :match (bijective ?R)
    :assert (injective ?R)
    :why "{?R} is bijective ⟹ injective."
    :priority 100)
  (rule
    bijective-total
    ()
    :match (bijective ?R)
    :assert (total ?R)
    :why "{?R} is bijective ⟹ total."
    :priority 100)
  (rule
    bijective-surjective
    ()
    :match (bijective ?R)
    :assert (surjective ?R)
    :why "{?R} is bijective ⟹ surjective."
    :priority 100)
  (rule
    derive-typecheck-arg-0
    ()
    :match (and (relation ?R ?A ?B) (bijective ?R))
    :assert (typecheck-arg-0 ?R ?A)
    :why "{?R} arg 0 typed {?A} ⟹ typecheck-arg-0 active."
    :priority 100)
  (rule
    derive-typecheck-arg-1
    ()
    :match (and (relation ?R ?A ?B) (bijective ?R))
    :assert (typecheck-arg-1 ?R ?B)
    :why "{?R} arg 1 typed {?B} ⟹ typecheck-arg-1 active."
    :priority 100)
  (rule
    derive-domain-elimination
    ()
    :match (and (functional ?R) (total ?R))
    :assert (domain-elimination ?R)
    :why "{?R} functional + total ⟹ domain-elimination active."
    :priority 100)
  (rule
    derive-range-elimination
    ()
    :match (and (injective ?R) (surjective ?R))
    :assert (range-elimination ?R)
    :why "{?R} injective + surjective ⟹ range-elimination active."
    :priority 100)
  (hrule
    guess
    (?R ?T1 ?T2)
    :match (and (is-a ?h ?T1) (is-a ?v ?T2))
    :assert (?R ?h ?v)
    :why "guess: ({?R} {?h} {?v})?"))

(ontology
  (relation is-a T T)
  (relation is-a* T T)
  (relation house-color House Color)
  (relation house-nation House Nationality)
  (relation house-drink House Drink)
  (relation house-smoke House Cigarette)
  (relation house-pet House Pet)
  (relation right-of House House)
  (relation next-to House House)
  (asymmetric is-a)
  (sibling-exclusive is-a is-a)
  (includes is-a is-a*)
  (transitive is-a*)
  (symmetric next-to)
  (includes right-of next-to)
  (bijective house-color)
  (bijective house-nation)
  (bijective house-drink)
  (bijective house-smoke)
  (bijective house-pet)
  (is-a Attribute T)
  (is-a House Attribute)
  (is-a Color Attribute)
  (is-a Nationality Attribute)
  (is-a Pet Attribute)
  (is-a Cigarette Attribute)
  (is-a Drink Attribute)
  (is-a House_1 House)
  (is-a House_2 House)
  (is-a House_3 House)
  (is-a House_4 House)
  (is-a House_5 House)
  (is-a Red Color)
  (is-a Green Color)
  (is-a Ivory Color)
  (is-a Yellow Color)
  (is-a Blue Color)
  (is-a Englishman Nationality)
  (is-a Spaniard Nationality)
  (is-a Ukrainian Nationality)
  (is-a Norwegian Nationality)
  (is-a Japanese Nationality)
  (is-a Dog Pet)
  (is-a Snail Pet)
  (is-a Fox Pet)
  (is-a Horse Pet)
  (is-a Zebra Pet)
  (is-a Old_Gold Cigarette)
  (is-a Kools Cigarette)
  (is-a Chesterfields Cigarette)
  (is-a Lucky_Strike Cigarette)
  (is-a Parliament Cigarette)
  (is-a Coffee Drink)
  (is-a Tea Drink)
  (is-a Milk Drink)
  (is-a Juice Drink)
  (is-a Water Drink))

(facts
  (right-of House_2 House_1 :source "condition (1)")
  (right-of House_3 House_2 :source "condition (1)")
  (right-of House_4 House_3 :source "condition (1)")
  (right-of House_5 House_4 :source "condition (1)")
  (linked house-nation Englishman house-color Red :source "condition (2)")
  (linked house-nation Spaniard house-pet Dog :source "condition (3)")
  (linked house-drink Coffee house-color Green :source "condition (4)")
  (linked house-nation Ukrainian house-drink Tea :source "condition (5)")
  (cross-attr-spatial-fwd
    house-color
    Ivory
    house-color
    Green
    right-of
    :source "condition (6)")
  (cross-attr-spatial-bwd
    house-color
    Ivory
    house-color
    Green
    right-of
    :source "condition (6)")
  (linked house-smoke Old_Gold house-pet Snail :source "condition (7)")
  (linked house-smoke Kools house-color Yellow :source "condition (8)")
  (house-drink House_3 Milk :source "condition (9)")
  (house-nation House_1 Norwegian :source "condition (10)")
  (cross-attr-spatial-fwd
    house-smoke
    Chesterfields
    house-pet
    Fox
    next-to
    :source "condition (11)")
  (cross-attr-spatial-bwd
    house-smoke
    Chesterfields
    house-pet
    Fox
    next-to
    :source "condition (11)")
  (cross-attr-spatial-fwd
    house-smoke
    Kools
    house-pet
    Horse
    next-to
    :source "condition (12)")
  (cross-attr-spatial-bwd
    house-smoke
    Kools
    house-pet
    Horse
    next-to
    :source "condition (12)")
  (linked house-smoke Lucky_Strike house-drink Juice :source "condition (13)")
  (linked house-nation Japanese house-smoke Parliament :source "condition (14)")
  (cross-attr-spatial-fwd
    house-nation
    Norwegian
    house-color
    Blue
    next-to
    :source "condition (15)")
  (cross-attr-spatial-bwd
    house-nation
    Norwegian
    house-color
    Blue
    next-to
    :source "condition (15)"))

(query
  :mode solve
  :goal (and (house-drink ?h_water Water) (house-pet ?h_zebra Zebra))
  :hrules (guess (house-color House Color) (house-nation House Nationality) (house-drink House Drink) (house-smoke House Cigarette) (house-pet House Pet)))
