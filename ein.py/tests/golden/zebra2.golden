(config :enable-pre-branch-lookahead true)

(rules
  (rule
    symmetric
    (?rel)
    :match (?rel ?a ?b)
    :assert (?rel ?b ?a)
    :why "{?rel} is symmetric: {?a} ↔ {?b}."
    :priority 100)
  (rule
    transitive
    (?rel)
    :match (and (?rel ?a ?b) (?rel ?b ?c) (neq ?a ?c))
    :assert (?rel ?a ?c)
    :why "{?rel} is transitive."
    :priority 200)
  (rule
    includes
    (?p ?q)
    :match (?p ?a ?b)
    :assert (?q ?a ?b)
    :why "{?q} includes {?p}: from {?a} →{?p}→ {?b}, derive {?a} →{?q}→ {?b}."
    :priority 100)
  (rule
    asymmetric
    (?rel)
    :match (and (?rel ?a ?b) (neq ?a ?b))
    :assert (not (?rel ?b ?a))
    :why "{?rel} is asymmetric: ¬({?b} →{?rel}→ {?a})."
    :priority 100)
  (rule
    sibling-exclusive
    (?siblings-via ?exclusive-under)
    :match (and (?siblings-via ?a ?P) (?siblings-via ?b ?P) (neq ?a ?b))
    :assert (not (?exclusive-under ?a ?b))
    :why "{?a} and {?b} share parent {?P} under {?siblings-via}; exclusive under {?exclusive-under}."
    :priority 300)
  (rule
    functional
    (?R)
    :match (and (?R ?a ?b) (?R ?a ?c) (neq ?b ?c))
    :assert (false)
    :why "{?R} not functional at {?a}: has {?b} and {?c}."
    :priority 250)
  (rule
    linked
    (?R1 ?V1 ?R2 ?V2)
    :match (?R1 ?h ?V1)
    :assert (?R2 ?h ?V2)
    :why "linked: ({?R1} {?h} {?V1}) ⟹ ({?R2} {?h} {?V2})."
    :priority 200)
  (rule
    cross-attr-right-of-fwd
    (?R ?V_left ?V_right)
    :match (and (?R ?h_l ?V_left) (right-of ?h_r ?h_l))
    :assert (?R ?h_r ?V_right)
    :why "({?R} {?h_l} {?V_left}) + right-of {?h_r} {?h_l} ⟹ ({?R} {?h_r} {?V_right})."
    :priority 200)
  (rule
    cross-attr-right-of-bwd
    (?R ?V_left ?V_right)
    :match (and (?R ?h_r ?V_right) (right-of ?h_r ?h_l))
    :assert (?R ?h_l ?V_left)
    :why "({?R} {?h_r} {?V_right}) + right-of {?h_r} {?h_l} ⟹ ({?R} {?h_l} {?V_left})."
    :priority 200)
  (rule
    cross-attr-next-to-unique
    (?R1 ?V1 ?R2 ?V2)
    :match (and (?R1 ?h1 ?V1) (next-to ?h1 ?h2) (absent (and (next-to ?h1 ?h_other) (neq ?h_other ?h2))))
    :assert (?R2 ?h2 ?V2)
    :why "({?R1} {?h1} {?V1}) at corner-house ⟹ ({?R2} {?h2} {?V2}) at the unique neighbour."
    :priority 200)
  (rule
    typecheck-arg-0
    (?R ?Dom)
    :match (and (?R ?a ?b) (absent (is-a ?a ?Dom)))
    :assert (false)
    :why "{?R} arg 0 expects {?Dom}; {?a} is not a {?Dom}."
    :priority 110)
  (rule
    typecheck-arg-1
    (?R ?Ran)
    :match (and (?R ?a ?b) (absent (is-a ?b ?Ran)))
    :assert (false)
    :why "{?R} arg 1 expects {?Ran}; {?b} is not a {?Ran}."
    :priority 110)
  (rule
    domain-elimination
    (?R ?OT ?VT)
    :match (and (functional ?R 0 1) (total ?R 0) (is-a ?a ?OT) (is-a ?v ?VT) (forall ?v_other (and (is-a ?v_other ?VT) (neq ?v_other ?v)) (not (?R ?a ?v_other))))
    :assert (?R ?a ?v)
    :priority 400
    :why "every {?VT} except {?v} excluded for {?a} → ({?R} {?a} {?v}).")
  (rule
    no-room-left
    (?R ?OT ?VT)
    :match (and (functional ?R 0 1) (total ?R 0) (is-a ?a ?OT) (forall ?v (is-a ?v ?VT) (not (?R ?a ?v))))
    :assert (false)
    :priority 110
    :why "{?a} has every {?VT} excluded — no value left.")
  (hrule
    guess
    (?R ?T1 ?T2)
    :match (and (is-a ?h ?T1) (is-a ?v ?T2))
    :assert (?R ?h ?v)
    :why "guess: ({?R} {?h} {?v})?"))

(ontology
  (relation is-a T T)
  (relation house-color House Color)
  (relation house-nation House Nationality)
  (relation house-drink House Drink)
  (relation house-smoke House Cigarette)
  (relation house-pet House Pet)
  (relation right-of House House)
  (relation next-to House House)
  (asymmetric is-a)
  (sibling-exclusive is-a is-a)
  (symmetric next-to)
  (includes right-of next-to)
  (functional house-color)
  (functional house-color 0 1)
  (functional house-color 1 0)
  (total house-color 0)
  (total house-color 1)
  (functional house-nation)
  (functional house-nation 0 1)
  (functional house-nation 1 0)
  (total house-nation 0)
  (total house-nation 1)
  (functional house-drink)
