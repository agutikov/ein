// ein-bot IR — kernel grammar
// Designed in S1.1.1 T1.1.1.1 + T1.1.1.2.
// See plans/m1_core_graph_reasoning/p1.1_ir_language/s1.1.1_grammar_design.md
//
// LEVEL B — structurally typed kernel, generic interiors.
//
// Enforced by the grammar:
//   1. Top level: exactly 5 reserved heads
//      ontology · facts · rules · query · trace
//   2. Inside (ontology …): only schema — type · relation · a-priori
//   3. Inside (facts …):    `=` (special) plus generic (NAME args*) forms
//   4. Inside (trace …):    only step · branch-open · branch-close ·
//                           contradiction · symmetry-class
//   5. :keyword value pair alternation — KEYWORD is never a value,
//      never appears twice in a row.
//   6. Heads of expression lists (inside values and patterns) must be
//      SYMBOL, VAR, WILDCARD, or "=" — never KEYWORD. (?var :key :key)
//      still fails via the kw_pair production, not via head restriction.
//
// Facts are generic. The keyword in head position names the relation
// (`(co-located A B)`), the meta-relation (`(instance N T)`,
// `(symmetric R)`), or anything the validator recognises. Property
// declarations move from relation prop-lists into rule-application
// facts: `(symmetric co-located)`, `(implies right-of next-to)`.
// `instance` moves from ontology to facts — it's an assertion about
// specific entities, not a schema item.
//
// Rule parameter lists are MANDATORY: `()` for non-generic rules,
// `(?p1 ?p2 …)` for generic rules.
//
// Deferred to the semantic validator (S1.1.2):
//   · which keywords are required per form (:match/:assert/:why in
//     rules; :rule/:using/:derives in steps; :mode/:goal in query)
//   · the named structural-predicate registry (A.4 closure)
//   · arity rules, ground-vs-pattern, type-checking of instance args,
//     unbound-variable checks, etc.
//
// This is the source of truth for the kernel shape. M2's GBNF for
// constrained LLM decoding is derived from this file by a Lark→GBNF
// translator (utils/lark_to_gbnf.py, planned for M2.P2.3).

start: form*

?form: ontology_form
     | facts_form
     | rules_form
     | query_form
     | trace_form

// ═══════════ Ontology (schema only) ═══════════
ontology_form: "(" "ontology" ontology_decl* ")"
?ontology_decl: type_decl | relation_decl | apriori_decl
type_decl:     "(" "type" SYMBOL [SYMBOL] ")"
relation_decl: "(" "relation" SYMBOL relation_sig kw_pair* ")"
apriori_decl:  "(" "a-priori" SYMBOL relation_sig kw_pair* ")"
relation_sig:   "(" SYMBOL+ ")"

// ═══════════ Facts (generic NAME args) ═══════════
facts_form: "(" "facts" fact_form* ")"
?fact_form: eq_fact | generic_fact
eq_fact:      "(" EQ value value kw_pair* ")"
generic_fact: "(" SYMBOL value* kw_pair* ")"

// ═══════════ Rules ═══════════
rules_form: "(" "rules" rule_decl* ")"
rule_decl: "(" "rule" SYMBOL rule_params kw_pair+ ")"
rule_params: "(" VAR* ")"

// ═══════════ Query ═══════════
query_form: "(" "query" kw_pair+ ")"

// ═══════════ Trace ═══════════
trace_form: "(" "trace" trace_event* ")"
?trace_event: step_decl
            | branch_open
            | branch_close
            | contradiction_decl
            | symmetry_decl
step_decl:          "(" "step" SYMBOL kw_pair* ")"
branch_open:        "(" "branch-open" SYMBOL kw_pair* ")"
branch_close:       "(" "branch-close" SYMBOL kw_pair* ")"
contradiction_decl: "(" "contradiction" SYMBOL kw_pair* ")"
symmetry_decl:      "(" "symmetry-class" SYMBOL kw_pair* ")"

// ═══════════ Value sub-language (interior of kw_pair) ═══════════
// Values never include KEYWORD — that's what enforces :kw value pair
// alternation. List heads in the pattern interior are restricted to
// SYMBOL / WILDCARD / "=" so VAR / KEYWORD can never be a head.
kw_pair: KEYWORD value
?value: generic_list | SYMBOL | VAR | WILDCARD | INT | RANGE | STRING
generic_list: "(" ")"
            | "(" list_head list_item* ")"
?list_head: SYMBOL | VAR | WILDCARD | EQ
?list_item: value | kw_pair

// ═══════════ Terminals ═══════════
SYMBOL:   /[A-Za-z][A-Za-z0-9_-]*/
VAR:      /\?[A-Za-z][A-Za-z0-9_-]*/
KEYWORD:  /:[a-z][A-Za-z0-9_-]*/
WILDCARD: "_"
EQ:       "="
RANGE:    /[0-9]+\.\.([0-9]+|\*)/
INT:      /-?[0-9]+/
STRING:   /"([^"\\]|\\.)*"/

LINE_COMMENT:  /;[^\n]*/
BLOCK_COMMENT: /#\|[\s\S]*?\|#/
%ignore LINE_COMMENT
%ignore BLOCK_COMMENT
%ignore /\s+/
