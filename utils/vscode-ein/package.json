{
  "name": "ein-lang",
  "displayName": "ein language",
  "description": "Syntax highlighting for Ein .ein puzzle files (TextMate grammar, no language server).",
  "version": "0.1.0",
  "publisher": "Ein",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/agutikov/ein.git" },
  "engines": { "vscode": "^1.60.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "ein",
        "aliases": ["ein", "Ein"],
        "extensions": [".ein"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ein",
        "scopeName": "source.ein",
        "path": "./ein.tmLanguage.json"
      }
    ]
  }
}
